@inherits LayoutComponentBase
<MudThemeProvider DefaultScrollbar="true" @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
<MudMainContent Class="pa-0 ma-0 overflow-hidden" Style="height: 100vh; background-color: #fbfbfb;">
        @Body
</MudMainContent>
</MudLayout>
@code{
    private MudTheme _theme = new(){
        PaletteLight = new PaletteLight()
        {
            Primary = Colors.Gray.Darken4,
        },
        PaletteDark = new PaletteDark()
        {
            Primary = Colors.Cyan.Darken4,
            Secondary="#80DEEA",
        },
    };
    bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
    private bool _isDarkMode;
}