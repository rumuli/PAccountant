@page "/persons"
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using Domain.Entities
@using Application.Services.Persons
@using Microsoft.AspNetCore.Authorization
@* @attribute [Authorize] *@
@inject IDialogService DialogService
@inject IPersonService PersonService

<PageTitle>Persons</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudDataGrid T="Person"
                 Items="@_person"
                 Hover="true"
                 Striped="true"
                 Bordered="true"
                 Dense="true"
                 Filterable="true"
                 Hideable="true" 
                 Dense="true"
                 RowClick="@RowClicked" 
                 SelectedItemsChanged="@SelectedItemsChanged">

        <!-- Toolbar -->
        <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Persons</MudText>
            <MudSpacer />

            <MudMenu Label="Add Person"
                     Variant="Variant.Filled"
                     EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                     Color="Color.Primary">

                <MudMenuItem Icon="@Icons.Material.Filled.Add"
                             OnClick="@OpenDialog">
                    Single
                </MudMenuItem>

                <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">
                    Import
                </MudMenuItem>

            </MudMenu>
        </ToolBarContent>

        <!-- Toolbar -->
        <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Persons</MudText>
            <MudSpacer />
            <MudMenu Label="Add Person" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="@(() => OpenDialog())">Single</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
            </MudMenu>
        </ToolBarContent>

        <!-- Columns -->
        <Columns>

        <PropertyColumn Property="x => x.Id"
                            Title="ID"
                            Sortable="true" />

               <PropertyColumn Property="x => x.FirstName"
                            Title="FirstName"
                            Sortable="true" />

              <PropertyColumn Property="x => x.LastName"
                            Title="LastName"
                            Sortable="true" /> 


               <PropertyColumn Property="x => x.Sex"
                            Title="Sex"
                            Sortable="true" /> 

               <PropertyColumn Property="x => x.phoneNumber"
                            Title="phoneNumber"
                            Sortable="true" /> 

               <PropertyColumn Property="x => x.Email"
                            Title="Email"
                            Sortable="true" /> 
                            
               <PropertyColumn Property="x => x.Country"
                            Title="Country"
                            Sortable="true" /> 

            <PropertyColumn Property="x => x.DateOfBirth"
                            Title="DateOfBirth"
                            Format="MM/dd/yyyy"
                            Sortable="true" />  

                            <PropertyColumn Property="x => x.Street"
                            Title="Street"
                            Sortable="true" /> 
                            <PropertyColumn Property="x => x.Status"
                            Title="Status"
                            Sortable="true" /> 
                            <PropertyColumn Property="x => x.CreatedBy"
                            Title="CreatedBy"
                            Sortable="true" /> 
         <MudTd DataLabel="Actions">
     
       <TemplateColumn Title="Actions" Context="context">
            <CellTemplate>
                  <MudStack Row="true" Spacing="2" Justify="Justify.Center">
                <MudButton Size="Size.Small" 
                           Variant="Variant.Filled" 
                           Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.Edit" 
                           OnClick="@(() => OpenEditDialog(context.Item.Id))">
                    Edit
                </MudButton>
                 <MudButton Size="Size.Small" 
                           Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           StartIcon="@Icons.Material.Filled.MoreHoriz"
                           OnClick="@(() => OpenDetailDialog(context.Item.Id))">
                    Details
                </MudButton>
                </MudStack>
            </CellTemplate>
          </TemplateColumn>
          </MudTd>
        </Columns>
    </MudDataGrid>
</MudContainer>


@code{
    List<Person> _person = new List<Person>();
        protected override void OnInitialized()
            {
                _person = PersonService.GetAllPersons();
            }  
            protected IDialogReference dialogReference;
            private Color GetStatusColor(string status)
            {
                return status switch
                {
                    "Active" => Color.Success,
                    "Completed" => Color.Info,
                    "Pending" => Color.Warning,
                    "Cancelled" => Color.Error,
                    _ => Color.Default
                };
            }
            private async Task OpenDialog(List<Person>? _person = null)
           {
            var dialog = await DialogService.ShowAsync<PersonCreateDialog>("Add person");
            var result = await dialog.Result;

            if (result != null && !result.Canceled)
            {
             _person = PersonService.GetAllPersons();
            }
        } 

            private async Task OpenDetailDialog(int id)
            {
                
            var parameters = new DialogParameters<PersonDetailDialog> { { x => x.Id, id } };
             await DialogService.ShowAsync<PersonDetailDialog>("View Details", parameters);
             }


           private async Task OpenEditDialog(int id)
           {
            var parameters = new DialogParameters<PersonEditDialog> { { x => x.Id, id } };
            var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
            
            var dialog = await DialogService.ShowAsync<PersonEditDialog>("Edit Person", parameters, options);
            var result = await dialog.Result;

            
          }

    private void LoadPersons()
    {
        _person = PersonService.GetAllPersons();
        StateHasChanged();
    }
    private void RowClicked(DataGridRowClickEventArgs<Person> args) { }
    private void SelectedItemsChanged(HashSet<Person> items) { }
}
