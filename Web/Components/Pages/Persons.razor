@page "/persons"
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using Domain.Entities
@using Application.Services.Persons
@using Microsoft.AspNetCore.Authorization
@inject IDialogService DialogService
@inject IPersonService PersonService

<PageTitle>Persons</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudDataGrid T="Person"
                 Items="@_person"
                 Hover="true"
                 Striped="true"
                 Bordered="true"
                 Dense="true"
                 Filterable="true"
                 SortMode="SortMode.Multiple"
                 Class="elevation-1"
                 RowClick="@RowClicked"
                 SelectedItemsChanged="@SelectedItemsChanged">

        <!-- Toolbar -->
        <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Persons</MudText>
            <MudSpacer />
            <MudMenu Label="Add Person" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="@(() => OpenDialog())">Single</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
            </MudMenu>
        </ToolBarContent>

        <!-- Columns -->
        <Columns>
            <SelectColumn T="Person" />

            <PropertyColumn Property="x => x.Id" Title="ID" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.FirstName" Title="First Name" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.LastName" Title="Last Name" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.Sex" Title="Sex" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.phoneNumber" Title="Phone Number" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.Email" Title="Email" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.Country" Title="Country" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.DateOfBirth" Title="Date of Birth" Format="MM/dd/yyyy" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.Street" Title="Street" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.Status" Title="Status" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.CreatedBy" Title="Created By" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />

            <!-- Actions Menu -->
            <TemplateColumn Title="Actions" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap">
                <CellTemplate>
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true" Size="Size.Small">
                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => OpenEditDialog(context.Item.Id))">Edit</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.Info" OnClick="@(() => OpenDetailDialog(context.Item.Id))">Details</MudMenuItem>
                        @* <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" OnClick="@(() => Snackbar.Add($"Deleting Person {context.Item.Id}", Severity.Error))">Delete</MudMenuItem> *@
                    </MudMenu>
                </CellTemplate>
            </TemplateColumn>
        </Columns>

        <!-- Pager -->
        <PagerContent>
            <MudDataGridPager T="Person" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
    List<Person> _person = new List<Person>();

    protected override void OnInitialized()
    {
        LoadPersons();
    }

    protected IDialogReference dialogReference;

    private Color GetStatusColor(string status)
    {
        return status switch
        {
            "Active" => Color.Success,
            "Completed" => Color.Info,
            "Pending" => Color.Warning,
            "Cancelled" => Color.Error,
            _ => Color.Default
        };
    }

    private async Task OpenDialog(List<Person>? _person = null)
    {
        var dialog = await DialogService.ShowAsync<PersonCreateDialog>("Add Person");
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            LoadPersons();
        }
    }

    private async Task OpenDetailDialog(int id)
    {
        var parameters = new DialogParameters<PersonDetailDialog> { { x => x.Id, id } };
        await DialogService.ShowAsync<PersonDetailDialog>("View Details", parameters);
    }

    private async Task OpenEditDialog(int id)
    {
        var parameters = new DialogParameters<PersonEditDialog> { { x => x.Id, id } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };

        var dialog = await DialogService.ShowAsync<PersonEditDialog>("Edit Person", parameters, options);
        var result = await dialog.Result;
    }

    private void LoadPersons()
    {
        _person = PersonService.GetAllPersons();
        StateHasChanged();
    }

    private void RowClicked(DataGridRowClickEventArgs<Person> args) { }
    private void SelectedItemsChanged(HashSet<Person> items) { }
}

