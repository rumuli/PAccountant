@page "/Expenses"
@using Domain.Entities
@using Application.Services.Expenses
@using MudBlazor
@inject IExpenseService ExpenseService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Expenses</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudDataGrid T="Expense"
                 Items="@_expenses"
                 Hover="true"
                 Striped="true"
                 Bordered="true"
                 Dense="true"
                 Filterable="true"
                 SortMode="SortMode.Multiple"
                 Class="elevation-1">

        

      <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Expense</MudText>
            <MudSpacer />
            <MudMenu Label="Add Expense" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">Single</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
            </MudMenu>
        </ToolBarContent>      

        <Columns>

        <SelectColumn T="Income" />

            <PropertyColumn Property="x => x.Id"
                            Title="ID"
                            HeaderStyle="white-space:nowrap"
                            ItemStyle="white-space:nowrap"
                            Sortable="true" />

            <PropertyColumn Property="x => x.ExpenseType.ExpenseTypeName"
                            Title="Expense Type"
                            HeaderStyle="white-space:nowrap"
                            ItemStyle="white-space:nowrap"
                            Sortable="true" />


            <PropertyColumn Property="x => x.Amount"
                            Title="Amount"
                            Format="C"
                            ItemStyle="white-space:nowrap"
                            HeaderStyle="white-space:nowrap"
                            Sortable="true" />

             <!-- Changed: show AccountType instead of DepositedAccount -->
           <PropertyColumn Property="x => x.Account.AccountNumber"
                Title=" Account"
                ItemStyle="white-space:nowrap"
                HeaderStyle="white-space:nowrap"
                Sortable="true" />

        

            <PropertyColumn Property="x => x.PaidTo"
                            Title="PaidTo"
                            ItemStyle="white-space:nowrap"
                            HeaderStyle="white-space:nowrap"
                            Sortable="true" />

                            <PropertyColumn Property="x => x.Description"
                            Title="Description"
                            ItemStyle="white-space:nowrap"
                            HeaderStyle="white-space:nowrap"
                            Sortable="true" />



            <TemplateColumn Title="Status">
                <CellTemplate>
                    <MudChip T="string"
                             Color="@(context.Item.IsActive ? Color.Success : Color.Error)"
                             Text="@(context.Item.IsActive ? "Active" : "Inactive")"
                             Variant="Variant.Filled"
                             ItemStyle="white-space:nowrap"
                             HeaderStyle="white-space:nowrap"
                             Size="Size.Small" />
                </CellTemplate>
            </TemplateColumn>

            <PropertyColumn Property="x => x.CreatedAt"
                            Title="Created Date"
                            Format="MM/dd/yyyy"
                            ItemStyle="white-space:nowrap"
                            HeaderStyle="white-space:nowrap"
                            Sortable="true" />

 <!-- Actions -->
            <TemplateColumn Title="Actions">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Info"
                                   Color="Color.Info"
                                   Size="Size.Small"
                                  Href="@($"/incomes/edit/{context.Item.Id}")" />
                                  
                                

                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Href="@($"/incomes/edit/{context.Item.Id}")" />
                            
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
</MudContainer>

       @code{
        private List<Expense> _expenses = new();
            protected override async Task OnInitializedAsync()
            {
                await LoadExpenses();
            }

            private async Task OpenCreateDialog()
            {
                var option = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
                await DialogService.ShowAsync<CreateExpenseDialog>(title: "Create Expense", new DialogParameters()
                {
                    { "OnExpenseCreated", EventCallback.Factory.Create(this, LoadExpenses) }
                }, option);
            }

            private async Task LoadExpenses()
            {
                _expenses = await ExpenseService.GetAllExpensesAsync();
                StateHasChanged();
            }

       }