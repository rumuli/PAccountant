@* @page "/" *@
@page "/account/login"
@layout Layout.AuthLayout

@using MudBlazor
@using Microsoft.AspNetCore.Components
@inject NavigationManager Navigation

@* The Container centers everything on the screen with a light background *@
<MudContainer MaxWidth="MaxWidth.False" Class="d-flex align-center justify-center pa-0" Style="height: 100vh; background-color: #f5f5f5;">
    
    @* Main Small Card *@
    <MudPaper Elevation="4" Class="d-flex overflow-hidden" Style="width: 850px; height: 550px; border-radius: 24px;">
        
        <MudGrid Spacing="0">
            @* Left Side: Dark Marketing (Hidden on mobile) *@
            <MudItem md="5" Class="d-none d-md-flex flex-column align-center justify-center pa-10" Style="background-color: #1a1512; color: white;">
                <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight: 700; line-height: 1.2;" Class="mb-6">
                    Manage <br /> your money
                </MudText>
                
                @* MudBlazor-based Visual Representation *@
                <MudPaper Elevation="0" Style="width: 140px; height: 260px; background: #222; border: 4px solid #333; border-radius: 20px;" Class="pa-3">
                    <MudPaper Style="height: 8px; width: 40px; background: #333; margin: 0 auto 15px auto;" Elevation="0" />
                    <MudPaper Style="height: 30px; width: 100%; background: #023d28; border-radius: 4px;" Elevation="0" Class="mb-2" />
                    <MudPaper Style="height: 90px; width: 100%; background: #444; border-radius: 4px;" Elevation="0" />
                </MudPaper>
                
                <MudText Typo="Typo.caption" Class="mt-8" Style="opacity: 0.5;">© 2026 PAccountant</MudText>
            </MudItem>

            @* Right Side: Login Form *@
            <MudItem xs="12" md="7" Class="pa-12 d-flex flex-column" Style="background-color: white;">
                
                @* Top Branding Bar *@
                <div class="d-flex align-center mb-10">
                    <MudIcon Icon="@Icons.Material.Filled.Circle" Style="color: #023d28;" Size="Size.Small" Class="mr-2" />
                    <MudText Typo="Typo.h6" Style="font-weight: 800;">PAccountant</MudText>
                    <MudSpacer />
                    <MudLink href="/RegisterUser" Underline="Underline.None" Color="Color.Primary" Style="font-size: 0.85rem; font-weight: 600;">Sign Up</MudLink>
                </div>

                <MudText Typo="Typo.h5" Class="mb-6" Style="font-weight: 700;">Sign In</MudText>

                <form method="post" action="/api/account/login">
                    <AntiforgeryToken />
                    <input type="hidden" name="returnUrl" value="@ReturnUrl" />

                    @if (!string.IsNullOrEmpty(Error))
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4" Variant="Variant.Outlined">@Error</MudAlert>
                    }

                    <MudTextField @bind-Value="email"
                                  Label="Email or Username"
                                  name="email"
                                  InputType="InputType.Email" 
                                  Variant="Variant.Outlined" 
                                  Margin="Margin.Dense"
                                  Class="mb-4" />

                    <MudTextField @bind-Value="password" 
                                  Label="Password"
                                  name="password"
                                  InputType="@_passwordInput"
                                  Variant="Variant.Outlined" 
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.End" 
                                  AdornmentIcon="@_passwordInputIcon" 
                                  OnAdornmentClick="TogglePasswordVisibility" />

                    <div class="d-flex justify-start mt-2 mb-8">
                        <MudLink Typo="Typo.body2" Style="color: #023d28; font-weight: 600; text-decoration: none;">Forgot password?</MudLink>
                    </div>

                    @* Custom Gradient Button via Inline Style *@
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               FullWidth="true" 
                               Class="py-3 shadow-none"
                               Style="background: linear-gradient(90deg, #023d28 0%, #023d28 100%); color: white; border-radius: 25px; text-transform: none; font-weight: 700;">
                        Sign In
                    </MudButton>
                </form>

                @* Language/Footer Context *@
                <MudSpacer />
                <div class="d-flex justify-space-between align-center" style="opacity: 0.5;">
                    <MudText Typo="Typo.caption">English</MudText>
                    <MudText Typo="Typo.caption">Contact Us</MudText>
                </div>
            </MudItem>
        </MudGrid>
    </MudPaper>
</MudContainer>


@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    private string email = "";
    private string password = "";
    private bool _isPasswordVisible = false;
    private bool rememberMe = false;
    private InputType _passwordInput = InputType.Password;
   private string _passwordInputIcon = Icons.Material.Filled.VisibilityOff;

    @* protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/", forceLoad: true);
        }
    } *@

    private List<MockOrder> _mockRows = new()
{
    new(5298, "iPad Gen 10", "Paid", Color.Success),
    new(5299, "iPhone 15", "Pending", Color.Warning),
    new(5300, "MacBook Air", "Paid", Color.Success)
};
public record MockOrder(int Id, string Name, string Status, Color Color);

public void TogglePasswordVisibility()
{
    if (_isPasswordVisible)
    {
        _isPasswordVisible = false;
        _passwordInputIcon = Icons.Material.Filled.VisibilityOff;
        _passwordInput = InputType.Password;
    }
    else
    {
        _isPasswordVisible = true;
        _passwordInputIcon = Icons.Material.Filled.Visibility;
        _passwordInput = InputType.Text;
    }
}

}
