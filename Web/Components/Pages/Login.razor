            Don't have an account?
            <MudLink Href="/RegisterUser" Class="ml-1">
                Register here
            </MudLink>
        </MudText>

    </MudPaper>

</MudContainer> *@
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-0 ma-0 overflow-hidden" Style="height: 100vh; background-color: #fbfbfb;">
<MudGrid Spacing="0" Style="height: 100%;">

    @* Left Column: Login Form *@
    <MudItem xs="12" md="6" Class="d-flex flex-column justify-center align-center relative px-8 py-12">
        
        @* Top Left Branding *@
        <div style="position: absolute; top: 40px; left: 40px;" class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Autorenew" Color="Color.Primary" Size="Size.Large" Class="mr-2" />
            <MudText Typo="Typo.h5" Style="font-weight: 700; color:">PAccount</MudText>
        </div>

        <div style="max-width: 400px; width: 100%;">
            <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-2" Style="font-weight: 800;">Welcome Back</MudText>
            @* <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary" Class="mb-8">
                Enter your email and password to access your account.
            </MudText> *@
        @if (!string.IsNullOrEmpty(Error))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">
                @Error
            </MudAlert>
        }

            <form method="post" action="/api/account/login" >
                <AntiforgeryToken />
                  <input type="hidden" name="returnUrl" value="@ReturnUrl" />
                <MudText Typo="Typo.body2" Class="mb-1 ml-1" Style="font-weight: 600;">Email</MudText>
                <MudTextField @bind-Value="email"
                              name="email"
                              InputType="InputType.Email" 
                              Variant="Variant.Outlined" 
                              Placeholder="crmstore@company.com" 
                              Margin="Margin.Dense"
                              Class="mb-4" />

                <div class="d-flex justify-space-between align-center mb-1 ml-1">
                    <MudText Typo="Typo.body2" Style="font-weight: 600;">Password</MudText>
                </div>
                <MudTextField @bind-Value="password" 
                              name="password"
                              InputType="@_passwordInput"
                              Variant="Variant.Outlined" 
                              Placeholder="5ellostore." 
                              Margin="Margin.Dense"
                              Adornment="Adornment.End" 
                              AdornmentIcon="@_passwordInputIcon" 
                              OnAdornmentClick="TogglePasswordVisibility" />

                @* <div class="d-flex align-center justify-space-between mt-2 mb-6">
                    <MudCheckBox @bind-Value="rememberMe" name="rememberMe" Label="Remember Me" Color="Color.Primary" Dense="true" T="bool" />
                    <MudLink Typo="Typo.body2" Color="Color.Primary" Underline="Underline.None" Style="font-weight: 600;">Forgot Your Password?</MudLink>
                </div> *@

                <MudButton Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           ButtonType="ButtonType.Submit"
                           FullWidth="true" 
                           Size="Size.Large" 
                           Class="py-3 rounded-lg shadow-none mb-6 mt-4"
                           Style="text-transform: none; font-weight: 700;">
                    Log In
                </MudButton>

                <div class="d-flex align-center mb-6">
                    <hr style="flex-grow: 1; border: none; border-top: 1px solid #e0e0e0;" />
                    <MudText Typo="Typo.caption" Class="mx-4" Color="Color.Primary">Or Login With</MudText>
                    <hr style="flex-grow: 1; border: none; border-top: 1px solid #e0e0e0;" />
                </div>

                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudButton Variant="Variant.Outlined" FullWidth="true" Class="py-2" Style="text-transform: none;">
                            <MudIcon Icon="@Icons.Custom.Brands.Google" Size="Size.Small" Class="mr-2" Color="Color.Dark"/> Google
                        </MudButton>
                    </MudItem>
                    <MudItem xs="6">
                        <MudButton Variant="Variant.Outlined" FullWidth="true" Class="py-2" Style="text-transform: none;">
                            <MudIcon Icon="@Icons.Custom.Brands.Apple" Size="Size.Small" Class="mr-2" /> Apple
                        </MudButton>
                    </MudItem>
                </MudGrid>

                <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-8" Color="Color.Primary">
                    Don't Have An Account? <MudLink href="/RegisterUser" Color="Color.Primary" Underline="Underline.None" Style="font-weight: 700;">Register Now.</MudLink>
                </MudText>
            </form>
        </div>

        @* Footer *@
        <div style="position: absolute; bottom: 40px; width: 100%;" class="px-10 d-flex justify-space-between align-center">
            <MudText Typo="Typo.caption" Color="Color.Primary">Copyright © 2026 PAccount.</MudText>
            <MudLink Typo="Typo.caption" Color="Color.Primary">Privacy Policy</MudLink>
        </div>
    </MudItem>

    @* Right Column: Visual Showcase *@
    <MudItem xs="0" md="6" Class="d-none d-md-flex flex-column justify-center align-center relative pa-12" 
             Style="border-radius: 40px 0 0 40px; color: white; overflow: hidden; background: linear-gradient(135deg, #22a075 0%, #064632 100%);">
    
        @* Decorative Background Circles *@
        <div style="position: absolute; top: -100px; right: -100px; width: 400px; height: 400px; background: rgba(255,255,255,0.05); border-radius: 50%;"></div>
        <div style="position: absolute; bottom: -50px; left: -50px; width: 300px; height: 300px; background: rgba(255,255,255,0.05); border-radius: 50%;"></div>

        <div style="z-index: 2; width: 100%; max-width: 500px;">
            <MudText Typo="Typo.h3" Style="font-weight: 700; line-height: 1.2;" Class="mb-6">
                Effortlessly manage your finances.
            </MudText>
            <MudText Typo="Typo.h6" Style="font-weight: 400; opacity: 0.9;" Class="mb-10">
                Log in to access your PAccount dashboard and manage your finances.
            </MudText>

            @* Mock Dashboard Image/Element *@
            <MudPaper Elevation="25" Class="pa-4 rounded-xl relative" Style="background-color: white; min-height: 350px;">
                @* Simplified Header Mockup *@
                <div class="d-flex justify-space-between mb-4">
                    <div style="height: 12px; width: 60px; background: #eee; border-radius: 6px;"></div>
                    <div style="height: 12px; width: 40px; background: #eee; border-radius: 6px;"></div>
                </div>
                
                @* Grid items to simulate the UI in the screenshot *@
                <MudGrid Spacing="2">
                    <MudItem xs="4">
                        <MudPaper Class="pa-3 rounded-lg" Elevation="0" Style="background: #f8f9ff;">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Total Earnings</MudText>
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 800; color: #333;">$189,374</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="8">
                        <MudPaper Class="pa-3 rounded-lg" Elevation="0" Style="background: #f8f9ff;">
                            <div class="d-flex justify-space-between">
                                 <MudText Typo="Typo.caption" Color="Color.Secondary">Budget</MudText>
                                 <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" Color="Color.Success"/>
                            </div>
                            <div style="height: 20px; width: 100%; background: linear-gradient(90deg, teal 30%, #eee 30%); border-radius: 10px; margin-top: 4px;"></div>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12">
                         <MudTable Items="_mockRows" Elevation="0" Dense="true" Class="rounded-lg mt-2">
                            <HeaderContent>
                                <MudTh><MudText Typo="Typo.caption" Style="font-weight:700">ID</MudText></MudTh>
                                <MudTh><MudText Typo="Typo.caption" Style="font-weight:700">Asset</MudText></MudTh>
                                <MudTh><MudText Typo="Typo.caption" Style="font-weight:700">Status</MudText></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="ID"><MudText Typo="Typo.caption">#@context.Id</MudText></MudTd>
                                <MudTd DataLabel="Product"><MudText Typo="Typo.caption">@context.Name</MudText></MudTd>
                                <MudTd DataLabel="Status">
                                    <MudChip T="string" Color="@context.Color" Size="Size.Small" Style="font-size: 10px; height: 18px;">@context.Status</MudChip>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudItem>
                </MudGrid>

                @* Floating Chart Decoration *@
                <MudPaper Elevation="10" Class="pa-4 rounded-xl absolute d-flex flex-column align-center" 
                          Style="bottom: -20px; right: -40px; width: 160px; background: white; border: 1px solid #eee;">
                     <MudText Typo="Typo.caption" Style="font-weight: 700;">Expenses</MudText>
                     <MudProgressCircular Value="75" Color="Color.Success" Size="Size.Large" Class="my-2" />
                     <MudText Typo="Typo.caption" Style="font-weight: 800;">$ 6,248</MudText>
                </MudPaper>
            </MudPaper>
        </div>
    </MudItem>
</MudGrid>


</MudContainer>


@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    private string email = "";
    private string password = "";
    private bool _isPasswordVisible = false;
    private bool rememberMe = false;
    private InputType _passwordInput = InputType.Password;
   private string _passwordInputIcon = Icons.Material.Filled.VisibilityOff;

    @* protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/", forceLoad: true);
        }
    } *@

    private List<MockOrder> _mockRows = new()
{
    new(5298, "iPad Gen 10", "Paid", Color.Success),
    new(5299, "iPhone 15", "Pending", Color.Warning),
    new(5300, "MacBook Air", "Paid", Color.Success)
};
public record MockOrder(int Id, string Name, string Status, Color Color);

public void TogglePasswordVisibility()
{
    if (_isPasswordVisible)
    {
        _isPasswordVisible = false;
        _passwordInputIcon = Icons.Material.Filled.VisibilityOff;
        _passwordInput = InputType.Password;
    }
    else
    {
        _isPasswordVisible = true;
        _passwordInputIcon = Icons.Material.Filled.Visibility;
        _passwordInput = InputType.Text;
    }
}

}
