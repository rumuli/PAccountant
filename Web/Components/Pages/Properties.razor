@page "/Property"
@using Application.Services.Properties
@using Domain.ValueObjects
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using Domain.Entities
@using Microsoft.AspNetCore.Authorization
@inject IDialogService DialogService
@inject IPropertyService PropertyService

<PageTitle>Property</PageTitle>
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <!-- Category summary cards -->
    <MudGrid GutterSize="GutterSize.Small" >
        @foreach (var kv in propertyCountsByCategory)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">@kv.Key</MudText>
                        <MudText Typo="Typo.subtitle1" Color="Color.Success" Class="fw-bold">@kv.Value</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
     <MudDataGrid T="Property"
                 Items="@_property"
                 MultiSelection="true" 
                 SortMode="SortMode.Multiple" 
                 Filterable="true"
                 Hideable="true" 
                 Dense="true"
                 RowClick="@RowClicked" 
                 SelectedItemsChanged="@SelectedItemsChanged">

             <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Property</MudText>
            <MudSpacer />

            <MudMenu Label="Add Property"
                     Variant="Variant.Filled"
                     EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                     Color="Color.Primary">

                <MudMenuItem Icon="@Icons.Material.Filled.Add"
                             OnClick="OpenDialog">
                    Single
                </MudMenuItem>

                <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">
                    Import
                </MudMenuItem>

            </MudMenu>
        </ToolBarContent>    

        <!-- Toolbar -->
        <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Properties</MudText>
            <MudSpacer />
            <MudMenu Label="Add Property" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="@(() => OpenDialog())">Single</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
            </MudMenu>
        </ToolBarContent>

        <!-- Columns -->
        <Columns>
            <SelectColumn T="Property" />

       <SelectColumn T="Property" />
        <PropertyColumn Property="x => x.Id"
                            Title="ID"
                            Sortable="true" />

        <PropertyColumn Property="x => x.Name"
                            Title="ID"
                            Sortable="true" />


        <PropertyColumn Property="x => x.PropertyCategory.Name"
                            Title="Category"
                            Sortable="true" /> 

        @* <PropertyColumn Property="x => x.Person.FirstName"
                            Title=" Owner"
                            Sortable="true" /> *@
                                   
              
               <PropertyColumn Property="x => x.Value"
                            Title="Value"
                            Sortable="true" />

              @* <PropertyColumn Property="x => x.Location"
                            Title="Location"
                            Sortable="true" />  *@


               <PropertyColumn Property="x => x.AssignedTo"
                            Title="AssignedTo"
                            Sortable="true" /> 

               @* <PropertyColumn Property="x => x.PurchasePrice"
                            Title="PurchasePrice"
                            Sortable="true" />  *@

               <PropertyColumn Property="x => x.Identification"
                            Title="Identification"
                            Sortable="true" /> 
                            
             
            @* <PropertyColumn Property="x => x.PurchaseDate"
                            Title="PurchaseDate"
                            Format="MM/dd/yyyy"
                            Sortable="true" />   *@
    <TemplateColumn Title="Status">
                <CellTemplate>
                    <MudChip T="string" 
                            Color="@GetStatusColor(context.Item.Status)" 
                            Size="Size.Small" 
                            Variant="Variant.Text">
                        @context.Item.Status
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>
         <MudTd DataLabel="Actions">
     
       @* <TemplateColumn Title="Actions" Context="context">
            <CellTemplate>
                  <MudStack Row="true" Spacing="2" Justify="Justify.Center">
                <MudButton Size="Size.Small" 
                           Variant="Variant.Filled" 
                           Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.Edit" 
                           OnClick="@(() => OpenEditDialog(context.Item.Id))">
                    Edit
                </MudButton>
                 <MudButton Size="Size.Small" 
                           Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           StartIcon="@Icons.Material.Filled.MoreHoriz"
                           OnClick="@(() => OpenDetailDialog(context.Item.Id))">
                    Details
                </MudButton>
                </MudStack>
            </CellTemplate>
        </TemplateColumn> *@
        
         <TemplateColumn Title="Actions" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap">
                <CellTemplate>
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true" Size="Size.Small">
                        @* Ensure the method name here matches exactly what is in @code *@
                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => OpenEditDialog(context.Item.Id))">Edit</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.MonetizationOn" 
                                    IconColor="Color.Info" 
                                    OnClick="@(() => OpenDetailDialog(context.Item.Id))">
                            Details
                        </MudMenuItem>
                    </MudMenu>
                </CellTemplate>
            </TemplateColumn>
         </MudTd>

   
        </Columns>
        <PagerContent>
            <MudDataGridPager T="Property" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code{
       List<Property> _property = new List<Property>();
       Dictionary<string,int> propertyCountsByCategory = new();
        protected override async Task OnInitializedAsync()
            {
                @* _property = await PropertyService.GetAllPropertysAsync(); *@
                await LoadProperties();
            }  
            protected IDialogReference dialogReference;
    private Color GetStatusColor(PropertyStatus status)
    {
        return status.ToString() switch
        {
            "Active" => Color.Success,
            "Lost" => Color.Error,
            "InMaintenance" => Color.Info,
            "Sold" => Color.Primary,
            "InProgress" => Color.Warning,
            _ => Color.Default
        };
    }
          private async Task OpenDialog()
             {
            DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };
          
            var dialog = await DialogService.ShowAsync<CreatePropertyDialog>("Add Property", options);
            var result = await dialog.Result;

            if (result != null && !result.Canceled)
            {
              @* _property =await PropertyService.GetAllPropertysAsync(); *@

                LoadProperties();
            }
             
            
        } 

            private async Task OpenDetailDialog(int id)
            {
                
            var parameters = new DialogParameters<PropertyDetailDialog> { { x => x.Id, id } };
             await DialogService.ShowAsync<PropertyDetailDialog>("View Details", parameters);
             }


           private async Task OpenEditDialog(int id)
           {
            var parameters = new DialogParameters<EditPropertyDialog> { { x => x.Id, id } };
            var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
            
            var dialog = await DialogService.ShowAsync<EditPropertyDialog>("Edit Property", parameters, options);
            var result = await dialog.Result;

          }
          
     private async Task LoadProperties()
    {
        _property = await PropertyService.GetAllPropertysAsync();
        propertyCountsByCategory = _property
            .GroupBy(p => p.PropertyCategory?.Name ?? "Uncategorized")
            .ToDictionary(g => g.Key, g => g.Count());

        StateHasChanged();
        
    }
   private void RowClicked(DataGridRowClickEventArgs<Property> args) { }
    private void SelectedItemsChanged(HashSet<Property> items) { }
    
    
   }
     
