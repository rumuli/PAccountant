
@using System.ComponentModel.DataAnnotations;
@using Application.DTO
@using Application.Interfaces
@using Application.Services.Debts
@using Domain.Entities
@using MudBlazor




@inject IDebtService DebtService
@inject ISnackbar Snackbar

<MudDialog Style="border-radius:12px; overflow:hidden; max-width:400px;">
    <DialogContent>
        <MudPaper Elevation="0" Class="pa-4 mb-4" 
                  Style="background: linear-gradient(135deg, #023d28 0%, #057a52 100%); color:white;">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Payments" Size="Size.Large" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6">Record Payment</MudText>
                    <MudText Typo="Typo.caption">Updating your debt balance</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>

        <EditForm Model="Model" OnValidSubmit="OnValidSubmit">
            <DataAnnotationsValidator />
            
            @if(!string.IsNullOrEmpty(ErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true">@ErrorMessage</MudAlert>
            }

            <MudStack Spacing="3">
                <MudTextField Label="Amount to Pay"
                              Variant="Variant.Outlined"
                              @bind-Value="Model.AmountPaid"
                              For="@(() => Model.AmountPaid)"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.AttachMoney" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Style="height:48px; font-weight:bold;">
                    CONFIRM REPAYMENT
                </MudButton>
            </MudStack>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } // Change this from MudDialogInstance to IMudDialogInstance
     @* MudDialogInstance MudDialog { get; set; } *@
    [Parameter] public int DebtId { get; set; }
    
    private DebtRepaymentDTO Model = new();
    private string ErrorMessage;

    private async Task OnValidSubmit()
    {
        try 
        {
            ErrorMessage = null;
            await DebtService.DebtRepayment(DebtId, Model);
            
            Snackbar.Add("Payment successful!", Severity.Success);
            
            // Closing with 'Ok' tells the parent page to refresh the cards
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }
}


