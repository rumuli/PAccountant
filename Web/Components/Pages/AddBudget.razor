@using Application.DTO.Budget
@using Application.Services.BudgetServices
@inject IBudgetService BudgetService
@inject NavigationManager NavigationManager
@page "/budgets/add-budget"

<MudDialog>
    <TitleContent>
            <MudText Typo="Typo.h6">Create Budget</MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="@newBudget" OnValidSubmit="SaveBudget" >
            @if(!string.IsNullOrEmpty(ErrorMessage)){
                <MudAlert Severity="Severity.Error" Elevation="0">@ErrorMessage</MudAlert>
            }
            <MudGrid>
                <MudItem xs="12">
                <MudDatePicker @bind-Date="newBudget.StartingAt" Label="Starting At" Editable="true" Mask="@(new DateMask("0000-00-00"))" DateFormat="yyyy-MM-dd" Placeholder="Starting At" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12">
                <MudDatePicker @bind-Date="newBudget.EndingAt" Label="Ending At" Editable="true" Mask="@(new DateMask("0000-00-00"))" DateFormat="yyyy-MM-dd" Placeholder="Ending At" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12">
                <MudButton 
                    Variant="Variant.Filled" 
                    Color="Color.Primary" 
                    FullWidth="true" 
                    ButtonType="ButtonType.Submit" 
                    Style="height: 40px; font-weight: bold;">
                    SAVE
                </MudButton>
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    private CreateBudgetDTO newBudget = new();
    private List<GetBudgetDTO> _budgets = new();
    private void Cancel() => MudDialog.Cancel();
    private string ErrorMessage { get; set; }

private async Task SaveBudget()
{
    try
    {
        var createdBudget = await BudgetService.AddBudgetAsync(newBudget);
        
        MudDialog.Close(DialogResult.Ok(createdBudget));
    }
    catch(Exception ex)
    {
        ErrorMessage = ex.Message;
    }
}
}