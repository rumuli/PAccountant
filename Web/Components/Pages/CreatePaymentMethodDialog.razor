@using Application.DTO
@using Application.Services.PaymentMethods
@using MudBlazor
@inject IPaymentMethodService PaymentMethodService

<MudDialog Style="border-radius:20px; overflow:hidden; max-width:450px; border: 1px solid rgba(63, 81, 181, 0.1);">
    <DialogContent>
        @* Header Section: Indigo Gradient for a secure, financial feel *@
        <MudPaper Elevation="0"
                  Class="relative overflow-hidden"
                  Style="background: linear-gradient(135deg, #057a52 0%, #057a52 100%);
                         border-radius:16px; padding:24px; margin-bottom:24px; position:relative;">
            
            @* Background Icon for design depth *@
            <MudIcon Icon="@Icons.Material.Filled.Payments" 
                     Style="position:absolute; right:-15px; top:-15px; font-size:6rem; color:rgba(255,255,255,0.1);" />

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Style="position:relative; z-index:1;">
                <MudAvatar Color="Color.Default" Style="height:56px; width:56px; background: rgba(255,255,255,0.2); backdrop-filter: blur(4px);">
                    <MudIcon Icon="@Icons.Material.Filled.CreditCard" Style="color:white; font-size:1.8rem;" />
                </MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6"
                             Style="color:white; font-weight:800; letter-spacing:-0.5px;">
                        Payment Method
                    </MudText>
                    <MudText Typo="Typo.caption"
                             Style="color:rgba(255,255,255,0.8); font-size:0.85rem;">
                        Add a way to track your transactions
                    </MudText>
                </MudStack>
            </MudStack>
        </MudPaper>

        <EditForm Model="Model" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            
            <MudStack Spacing="4" Class="px-2">
                <div>
                    @* Styled Label with Vertical Indicator *@
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                        <MudDivider Vertical="true" FlexItem="true" Style="border-width: 3px; border-color: #057a52; height: 14px; border-radius: 2px;" />
                        <MudText Typo="Typo.caption"
                                 Style="color:#057a52; font-weight:900; letter-spacing:.12em; text-transform:uppercase;">
                            METHOD DETAILS
                        </MudText>
                    </MudStack>

                    <MudTextField T="string"
                                  Label="Payment Method Name"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" 
                                  @bind-Value="Model.PaymentMethodName"
                                  Placeholder="e.g. Bank Account, Cash, Visa"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Wallet"
                                  AdornmentColor="Color.Primary"
                                  For="@(() => Model.PaymentMethodName)"
                                  Style="background: white; border-radius:12px;" />
                </div>

                @if (ShowErrors)
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Text" Dense="true" Class="mt-2" 
                              Style="border-radius:8px; background: rgba(244, 67, 54, 0.05);">
                        An error occurred while saving. Please try again.
                    </MudAlert>
                }

                @* Action Button: Full width and styled to match *@
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           Disabled="@_isProcessing"
                           StartIcon="@(_isProcessing ? null : Icons.Material.Filled.Save)"
                           Style="width:100%; border-radius:12px; font-weight:700;
                                  background: #057a52;
                                  box-shadow: 0 6px 20px rgba(63, 81, 181, 0.25);
                                  padding: 12px 0; margin-top: 8px;">
                    @if (_isProcessing)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                        <MudText Class="ms-2">SAVING...</MudText>
                    }
                    else
                    {
                        <MudText>SAVE METHOD</MudText>
                    }
                </MudButton>
            </MudStack>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; }

    private CreatePaymentMethodDTO Model { get; set; } = new();
    private bool ShowErrors { get; set; } = false;
    private bool _isProcessing { get; set; }

    private async Task HandleValidSubmit()
    {
        _isProcessing = true;
        ShowErrors = false;
        
        try
        {
            await PaymentMethodService.CreatePaymentMethodAsync(Model);
            MudDialog.Close(DialogResult.Ok(true));  
        }
        catch
        {
            ShowErrors = true;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void Cancel() => MudDialog.Cancel(); 
}