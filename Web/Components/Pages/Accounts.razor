@page "/Accounts"
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using Domain.Entities
@using Application.Services.Accounts
@using Microsoft.AspNetCore.Authorization
@inject IDialogService DialogService
@inject IAccountService AccountService

<PageTitle>Accounts</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudDataGrid T="Account"
                 Items="@accounts"
                 Hover="true"
                 Striped="true"
                 Bordered="true"
                 Dense="true"
                 Filterable="true"
                 SortMode="SortMode.Multiple"
                 Class="elevation-1"
                 RowClick="@RowClicked"
                 SelectedItemsChanged="@SelectedItemsChanged">

        <!-- Toolbar -->
        <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Accounts</MudText>
            <MudSpacer />
            <MudMenu Label="Add Account" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="@(() => OpenDialog())">Single</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
            </MudMenu>
        </ToolBarContent>

        <!-- Columns -->
        <Columns>
            <SelectColumn T="Account" />

            <PropertyColumn Property="x => x.Id" Title="ID" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.AccountType.Name" Title="Account Type" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.AccountNumber" Title="Account Number" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.Provider" Title="Provider" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.Balance" Title="Balance" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.Status" Title="Status" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.UpdateBy" Title="Updated By" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.CreatedBy" Title="Created By" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.CreatedAt" Title="Created At" Format="MM/dd/yyyy" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />

            <!-- Actions Menu -->
            <TemplateColumn Title="Actions" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap">
                <CellTemplate>
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true" Size="Size.Small">
                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => OpenEditDialog(context.Item.Id))">Edit</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.Info" OnClick="@(() => OpenDetailDialog(context.Item.Id))">Details</MudMenuItem>
                        @* <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" OnClick="@(() => Snackbar.Add($"Deleting Account {context.Item.Id}", Severity.Error))">Delete</MudMenuItem> *@
                    </MudMenu>
                </CellTemplate>
            </TemplateColumn>
        </Columns>

        <!-- Pager -->
        <PagerContent>
            <MudDataGridPager T="Account" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
    List<Account> accounts = new List<Account>();
        protected override async Task OnInitializedAsync()
            {
                accounts = await AccountService.GetAllAccountsAsync();
            }  
            protected IDialogReference dialogReference;
            private Color GetStatusColor(string status)
            {
                return status switch
                {
                    "Active" => Color.Success,
                    "Completed" => Color.Info,
                    "Pending" => Color.Warning,
                    "Cancelled" => Color.Error,
                    _ => Color.Default
                };
            }
            private async Task OpenDialog(List<Account>? accounts = null)
           {
            var dialog = await DialogService.ShowAsync<CreateAccountDialog>("Add Account");
            var result = await dialog.Result;

            if (result != null && !result.Canceled)
            {
            accounts =await AccountService.GetAllAccountsAsync();
            }
        } 

            private async Task OpenDetailDialog(int id)
            {
                
            var parameters = new DialogParameters<AccountDetailDialog> { { x => x.Id, id } };
             await DialogService.ShowAsync<AccountDetailDialog>("View Details", parameters);
             }


           private async Task OpenEditDialog(int id)
           {
            var parameters = new DialogParameters<EditAccountDialog> { { x => x.Id, id } };
            var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
            
            var dialog = await DialogService.ShowAsync<EditAccountDialog>("Edit Account", parameters, options);
            var result = await dialog.Result;

            
          }

   }
     
