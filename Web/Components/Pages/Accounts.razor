@page "/Accounts"
@using Domain.Entities
@using Application.Services.Accounts
@using MudBlazor
@using Domain.ValueObjects
@using Web.Components.Shared
@inject IAccountService AccountService
@inject IDialogService DialogService

<PageTitle>Accounts</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
   
<MudGrid Spacing="3" Class="mb-4">
    <!-- Summary cards -->
    <MudItem xs="12" md="3">
            <StatCards
        Icon="@Icons.Material.Filled.KeyboardArrowDown"
        ValueColor="Color.Success"
        Title="Total Balance"
        Value="@accounts.Sum(x => x.Balance).ToString("C")"
        />
    </MudItem>

    <!-- Accounts by Status -->
    @foreach (var statusGroup in accounts.GroupBy(x => x.Status))
    {
        <MudItem xs="12" md="3">
            <StatCards
                Icon="@Icons.Material.Filled.AccountBalance"
                ValueColor="@GetStatusColor(statusGroup.Key)"
                Title="@statusGroup.Key.ToString()"
                Value="@statusGroup.Count().ToString()"
            />
        </MudItem>
    }
</MudGrid>

    
