@using Application.DTO
@using Application.Interface
@using Application.Services.Properties
@using Application.Services.PropertyCategories
@using MudBlazor
@inject IPropertycategoryService PropertyCategoryService
@inject ISnackbar Snackbar

@rendermode InteractiveServer 

<MudDialog Style="border-radius:20px; overflow:hidden; max-width:450px; border: 1px solid rgba(0, 150, 136, 0.1);">
    <DialogContent>
        @* Header Section: Teal Gradient for Real Estate/Property feel *@
        <MudPaper Elevation="0"
                  Class="relative overflow-hidden"
                  Style="background: linear-gradient(135deg, #057a52 0%, #057a52 100%);
                         border-radius:16px; padding:24px; margin-bottom:24px; position:relative;">
            
            @* Background Icon for design depth *@
            <MudIcon Icon="@Icons.Material.Filled.HomeWork" 
                     Style="position:absolute; right:-15px; top:-15px; font-size:6rem; color:rgba(255,255,255,0.1);" />

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Style="position:relative; z-index:1;">
                <MudAvatar Color="Color.Default" Style="height:56px; width:56px; background: rgba(255,255,255,0.2); backdrop-filter: blur(4px);">
                    <MudIcon Icon="@Icons.Material.Filled.MapsHomeWork" Style="color:white; font-size:1.8rem;" />
                </MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6"
                             Style="color:white; font-weight:800; letter-spacing:-0.5px;">
                        Property Category
                    </MudText>
                    <MudText Typo="Typo.caption"
                             Style="color:rgba(255,255,255,0.8); font-size:0.85rem;">
                        Classify your real estate assets
                    </MudText>
                </MudStack>
            </MudStack>
        </MudPaper>

        <EditForm Model="Model" OnValidSubmit="HandleValidSubmit" FormName="CreateCategory">
            <DataAnnotationsValidator />
            
            <MudStack Spacing="4" Class="px-2">
                <div>
                    @* Styled Label with Vertical Indicator *@
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                        <MudDivider Vertical="true" FlexItem="true" Style="border-width: 3px; border-color: #009688; height: 14px; border-radius: 2px;" />
                        <MudText Typo="Typo.caption"
                                 Style="color:#057a52; font-weight:900; letter-spacing:.12em; text-transform:uppercase;">
                            CATEGORY DETAILS
                        </MudText>
                    </MudStack>

                    <MudTextField T="string"
                                  Label="Category Name"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" 
                                  @bind-Value="Model.Name"
                                  Placeholder="e.g. Residential, Commercial, Land"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Label"
                                  AdornmentColor="Color.Primary"
                                  For="@(() => Model.Name)"
                                  Style="background: white; border-radius:12px;" />
                </div>

                @* Action Button inside EditForm *@
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           Disabled="@_isProcessing"
                           StartIcon="@(_isProcessing ? null : Icons.Material.Filled.Save)"
                           Style="width:100%; border-radius:12px; font-weight:700;
                                  background: #057a52;
                                  box-shadow: 0 6px 20px rgba(0, 150, 136, 0.25);
                                  padding: 12px 0; margin-top: 8px;">
                    @if (_isProcessing)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                        <MudText Class="ms-2">SAVING...</MudText>
                    }
                    else
                    {
                        <MudText>SAVE CATEGORY</MudText>
                    }
                </MudButton>
            </MudStack>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private PropertyCategoryCreateDTO Model { get; set; } = new() { CreatedBy = "Admin" };

    [Parameter] public EventCallback OnCategory { get; set; }
    
    private bool _isProcessing;

    private async Task HandleValidSubmit()
    {
        _isProcessing = true;
        try
        {
            await PropertyCategoryService.CreatePropertyCategory(Model);
            Snackbar.Add("New Category added successfully!", Severity.Success);
            
            if (OnCategory.HasDelegate)
                await OnCategory.InvokeAsync();

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}