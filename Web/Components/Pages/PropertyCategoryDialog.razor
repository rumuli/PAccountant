@using Application.DTO
@using Application.Interface
@using Application.Services.Properties
@using MudBlazor
@inject IPropertycategoryService PropertyCategoryService
@inject ISnackbar Snackbar


@rendermode InteractiveServer 

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-4 fw-bold">
            <MudIcon Icon="@Icons.Material.Filled.PostAdd" Class="mr-2"/> Create New Category
        </MudText>

  
        <EditForm Model="Model" OnValidSubmit="OnValidSubmit" FormName="CreateCatefory">
            <DataAnnotationsValidator />

            <MudStack Spacing="3">
                <MudTextField T="string"
                              Label="Type Name"
                              Variant="Variant.Outlined"
                              @bind-Value="Model.Name"
                              For="@(() => Model.Name)" />

                <MudTextField T="string"
                              Label="Status"
                              Variant="Variant.Outlined"
                              @bind-Value="Model.Status"
                              For="@(() => Model.Status)" />

                <MudTextField T="string"
                              Label="Created By"
                              Variant="Variant.Outlined"
                              @bind-Value="Model.CreatedBy"
                              ReadOnly="true" />
            </MudStack>
        </EditForm>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
        @* FIXED: Button must be inside or linked to the form to trigger OnValidSubmit *@
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   OnClick="OnValidSubmit">Save Category</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    // Model initialized with default "Admin" as seen in your Repository logic
    private PropertyCategoryCreateDTO Model { get; set; } = new() { CreatedBy = "Admin" };

    [Parameter] public EventCallback OnCategory { get; set; }

    private async Task OnValidSubmit()
    {
        try
        {
            await PropertyCategoryService.CreatePropertyCategory(Model);
            
            Snackbar.Add("New Category added successfully!", Severity.Success);
            await OnCategory.InvokeAsync();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel() => MudDialog.Cancel();
}