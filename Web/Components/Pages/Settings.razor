@page "/settings"
@using Application.Services.DebtTypes
@using Domain.Entities
@using Application.Services.PaymentMethods
@using Application.Services.AccountTypes
@using Application.Services.IncomeTypes
@using Application.Services.ExpenseTypes
@using Application.Services.PropertyCategories
@using Application.Services.DebtTypes
@inject IPaymentMethodService PaymentMethodService
@inject IDialogService DialogService
@inject IDialogService Dialog
@inject IAccountTypeService AccountTypeService
@inject IIncomeTypeService IncomeTypeService
@inject IExpenseTypeService ExpenseTypeService
@inject IPropertycategoryService PropertyCategoryService
