<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6 p-3">
<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-6">
    <MudTabPanel Text="Payment Method">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6 py-3">
    <MudDataGrid T="PaymentMethod"
                 Items="@PaymentMethods"
                 MultiSelection="true"
                 SortMode="SortMode.Multiple"
                 Filterable="true"
                 Hideable="true"
                 Dense="true"
                 Hover="true"
                 Striped="true"
                 
                 Class="elevation-1"
                 >

        <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Payment Methods</MudText>
            <MudSpacer />
            <MudMenu Label="Add PaymentMethod" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="@GoToCreatePaymentMethod">Single</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
            </MudMenu>
        </ToolBarContent>

        <Columns>
            <SelectColumn T="PaymentMethod" />

            <PropertyColumn Property="x => x.Id" Title="ID" Sortable="true" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" />
            <PropertyColumn Property="x => x.PaymentMethodName" Title="Method" Sortable="true" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" />
            @* <PropertyColumn Property="x => x.IsActive" Title="Status" Format="C" Sortable="true" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" /> *@
            @* <PropertyColumn Property="x => x.UpdatedAt" Title="Upadated At" Format="dd MMM yyyy" Sortable="true" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" /> *@
            <PropertyColumn Property="x => x.CreatedAt" Title="Create At" Format="dd MMM yyyy" Sortable="true" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" />

            <TemplateColumn Title="Status" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap">
                <CellTemplate>
                    <MudChip T="string"
                             Color="@(context.Item.IsActive ? Color.Success : Color.Error)"
                             Size="Size.Small"
                             Variant="Variant.Text">
                        @(context.Item.IsActive ? "Active" : "Inactive")
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>


            <TemplateColumn Title="Actions" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap">
                <CellTemplate>
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true" Size="Size.Small">
                        <MudMenuItem Icon="@Icons.Material.Filled.Info" >Details</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" >Edit</MudMenuItem>
                    </MudMenu>
                </CellTemplate>
            </TemplateColumn>
        </Columns>

        <PagerContent>
            <MudDataGridPager T="PaymentMethod" />
          </PagerContent>
    </MudDataGrid>
</MudContainer>
    </MudTabPanel>

