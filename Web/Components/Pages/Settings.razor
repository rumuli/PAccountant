@code{
    private List<PaymentMethod> PaymentMethods = new();
    private readonly DialogOptions _closeButton = new() { CloseButton = true };
    //Account Type
    private List<AccountType> AccountTypes = new();
    private readonly DialogOptions _closeButton2 = new() { CloseButton = true };

    //Income Type

    private List <IncomeType> IncomeTypes = new();
    private readonly DialogOptions _closeButton3 = new() { CloseButton = true };

    //Expense Type

    private List <ExpenseType> ExpenseTypes = new();
    private readonly DialogOptions _closeButton4 = new() { CloseButton = true };

    //Property Category
    private List <PropertyCategory> PropertyCategory = new(); 
     private readonly DialogOptions _closeButton5 = new() { CloseButton = true };     

     // Debt Type

     private List<DebtType> DebtTypes = new List<DebtType>();
     private readonly DialogOptions _closeButton6 = new() { CloseButton = true };   


    private async Task LoadPaymentMethod(){
        PaymentMethods = await PaymentMethodService.GetAllPaymentMethodsAsync();
        
    }
    private async Task LoadAccountType(){
        AccountTypes = await AccountTypeService.GetAllAccountTypes();
    }

    private async Task LoadIncomeType(){
        IncomeTypes = await IncomeTypeService.GetAllIncomeTypesAsync();
    }

    private async Task LoadExpenseType(){
        ExpenseTypes = await ExpenseTypeService.GetAllExpenseTypesAsync();
    }

    private async Task LoadPropertyCategory(){
        PropertyCategory = await PropertyCategoryService.GetAllPropertyCategorysAsync();
    }

    private async Task LoadDebtType(){
        DebtTypes = await DebtTypeService.GetAllDebtTypesAsync();
    }


    protected override async Task OnInitializedAsync()
    {
      await LoadPaymentMethod();
      await LoadAccountType();  
      await LoadIncomeType();
      await LoadExpenseType(); 
      await LoadPropertyCategory();
      await LoadDebtType();
    }

    
    private async Task GoToCreatePaymentMethod()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

        var dialog = await DialogService.ShowAsync<CreatePaymentMethodDialog>("Add Payment Method", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(50);
            await LoadPaymentMethod();
        }
        }

        // go to create Account type

        private async Task GoToCreateAccountType()
        {
             DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

        var dialog = await DialogService.ShowAsync<AccountTypeDialog>("Add Account Type", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(50);
            await LoadAccountType();
        }
            

    }
        private async Task GoToCreateIncomeType()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

        var dialog = await DialogService.ShowAsync<CreateIncomeTypeDialog>("Add Income Type", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(50);
            await LoadIncomeType();
        }
        }

          private async Task GoToCreateExpenseType()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

        var dialog = await DialogService.ShowAsync<CreateExpenseTypeDialog>("Add Expense Type", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(50);
            await LoadExpenseType();
        }
        }

        private async Task GoToCreatePropertyCategory()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

        var dialog = await DialogService.ShowAsync<PropertyCategoryDialog>("Add Property Category", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(50);
            await LoadPropertyCategory();
        }
        }

        private async Task GoToCreateDebtType()
        {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

        var dialog = await DialogService.ShowAsync<CreateDebtTypeDialog>("Add Debt Type", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(50);
            await LoadDebtType();
        }
        }
    }