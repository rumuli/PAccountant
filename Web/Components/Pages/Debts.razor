@page "/Debts"
@using Domain.Entities
@using Application.Services.Debts
@using MudBlazor
@inject IDebtService DebtService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    @* --- DASHBOARD SECTION --- *@
    <MudGrid Class="mb-6">
        @* Total Count Card *@
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="4" Class="pa-4" Style="background-color: var(--mud-palette-primary); color: white;">
                <MudText Typo="Typo.h6">Total Debts</MudText>
                <MudText Typo="Typo.h3"><b>@_debts.Count</b></MudText>
            </MudPaper>
        </MudItem>

        @* Full List Summary Card *@
        <MudItem xs="12" sm="6" md="9">
            <MudPaper Elevation="4" Class="pa-4" Style="max-height: 150px; overflow-y: auto;">
                <MudText Typo="Typo.subtitle2" Class="mb-2"><b>Quick List (All Items)</b></MudText>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var debt in _debts)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info">
                            ID: @debt.Id | @debt.Amount.ToString("n")
                        </MudChip>
                    }
                    @if (!_debts.Any())
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">No debts found in the list.</MudText>
                    }
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* --- YOUR ORIGINAL DATA GRID --- *@
    <MudDataGrid T="Debt"
                 Items="@_debts"
                 MultiSelection="true"
                 SortMode="SortMode.Multiple"
                 Filterable="true"
                 Hideable="true"
                 Dense="true"
                 Hover="true"
                 Striped="true"
                 Bordered="true"
                 Class="elevation-1">

        <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Debts</MudText>
            <MudSpacer />
            <MudMenu Label="Add Debt" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">Single</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
            </MudMenu>
        </ToolBarContent>

        <Columns>
            <SelectColumn T="Debt" />

            <PropertyColumn Property="x => x.Id" Title="ID" Sortable="true" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" />
            <PropertyColumn Property="x => x.DebtType.DebtTypeName" Title="Debt Type" Sortable="true" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" />
            <PropertyColumn Property="x => x.Amount" Title="Amount" Format="n" Sortable="true" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" />
            <PropertyColumn Property="x => x.Creditor" Title="Creditor" Sortable="true" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" />
            <PropertyColumn Property="x => x.DueDate" Title="Start Date" Format="dd MMM yyyy" Sortable="true" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" />
            <PropertyColumn Property="x => x.DateIncurred" Title="End Date" Format="dd MMM yyyy" Sortable="true" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" />

            <TemplateColumn Title="Status" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap">
                <CellTemplate>
                    <MudChip T="string"
                             Color="@(context.Item.IsActive ? Color.Success : Color.Error)"
                             Size="Size.Small"
                             Variant="Variant.Text">
                        @(context.Item.IsActive ? "Active" : "Inactive")
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>

            <PropertyColumn Property="x => x.CreatedAt" Title="Created Date" Format="MM/dd/yyyy" Sortable="true" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" />

            <TemplateColumn Title="Actions" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap">
                <CellTemplate>
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true" Size="Size.Small">
                        <MudMenuItem Icon="@Icons.Material.Filled.Info" OnClick="@(() => Snackbar.Add($"Viewing {context.Item.Id}", Severity.Info))">Details</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => Snackbar.Add($"Editing {context.Item.Id}", Severity.Info))">Edit</MudMenuItem>
                    </MudMenu>
                </CellTemplate>
            </TemplateColumn>
        </Columns>

        <PagerContent>
            <MudDataGridPager T="Debt" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
    private List<Debt> _debts = new();

    private readonly DialogOptions _closeButton = new() { CloseButton = true };

    private async Task LoadDebts()
    {
        _debts = await DebtService.GetAllDebtsAsync();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDebts();
    }

    private async Task OpenCreateDialog()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

        var dialog = await DialogService.ShowAsync<CreateDebtDialog>("Add Debt", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(50);
            await LoadDebts();
        }
    }
}