@using Application.DTO
@using Application.Services.Accounts
@using Application.Services.Expenses
@using Application.Services.ExpenseTypes
@using MudBlazor
@using Domain.Entities
@using System.ComponentModel.DataAnnotations

@inject IExpenseService ExpenseService
@inject IExpenseTypeService ExpenseTypeService
@inject IAccountService AccountService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService

<MudDialog Style="border-radius:0px; overflow:hidden; max-width: 750px;">
    <DialogContent>
        <MudPaper Elevation="0"
                  Class="pa-5 mb-6"
                  Style="background: linear-gradient(90deg,#023d28 0%,#057a52 100%);
                         border-radius:12px;color:white;">

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                <MudAvatar Style="height:60px;width:60px;background:rgba(255,255,255,0.2);">
                    <MudIcon Icon="@Icons.Material.Filled.ReceiptLong"
                             Style="font-size:2.5rem;color:white;" />
                </MudAvatar>

                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6" Style="font-weight:700;">
                        New Expense Record
                    </MudText>
                    <MudText Typo="Typo.body2"
                             Style="color:rgba(255,255,255,0.8);">
                        Fill in the details below
                    </MudText>
                </MudStack>
            </MudStack>
        </MudPaper>

        <EditForm Model="Model" OnValidSubmit="OnValidSubmit">
            <DataAnnotationsValidator />

            <MudGrid Spacing="3">
                <MudItem xs="12" sm="7">
                    <MudStack Spacing="3">
                        <MudDatePicker Label="Date"
                                       @bind-Date="Model.Date"
                                       @bind-Date:after="OnDateChanged"
                                       Variant="Variant.Outlined" />

                       <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudSelect T="int" Label="Expense Type" Value="Model.ExpenseTypeId" ValueChanged="OnExpenseTypeChanged"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                                       AdornmentIcon="@Icons.Material.Filled.Category" Adornment="Adornment.Start" AdornmentColor="Color.Primary">
                                <MudSelectItem Value="0">Select Expense Type</MudSelectItem>
                                @foreach (var type in ExpenseTypes) { <MudSelectItem Value="@type.Id">@type.ExpenseTypeName</MudSelectItem> }
                            </MudSelect>
                            @* <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Variant="Variant.Outlined" 
                                           Size="Size.Small" OnClick="@GoToCreateExpenseType" Style="height:40px; width:40px;" /> *@
                        </MudStack>

                             @if (remaining.HasValue)
                        {
                            <MudPaper Elevation="0" Class="pa-4" 
                                      Style="background: linear-gradient(135deg, #057a52 0%, #057a52 100%); border-radius:8px; color:white;">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    @if (isLoadingBudget) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" /> }
                                    else { <MudIcon Icon="@Icons.Material.Filled.Info" /> }
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.caption" Style="font-weight:700; opacity:0.9;">BUDGET STATUS</MudText>
                                        <MudText Typo="Typo.body2">Remaining: <b>@remaining.Value.ToString("n")</b></MudText>
                                    </MudStack>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudStack>
                </MudItem>

                <MudItem xs="12" sm="5">
                    <MudStack Spacing="3">
                        <MudTextField T="decimal"
                                      Label="Amount"
                                      @bind-Value="Model.Amount"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.AttachMoney" />

                        <MudSelect T="int"
                                   Label="Account"
                                   Value="Model.AccountId"
                                   ValueChanged="OnAccountChanged"
                                   Variant="Variant.Outlined">
                            <MudSelectItem Value="0">Select Account</MudSelectItem>
                            @foreach (var account in _accounts)
                            {
                                <MudSelectItem Value="@account.Id">@account.AccountNumber</MudSelectItem>
                            }
                        </MudSelect>

                        @if (accountBalance.HasValue)
                        {
                            <MudPaper Elevation="0"
                                      Class="pa-3"
                                      Style="background:#023d28;color:white;border-radius:8px; min-height:64px;">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    @if (isLoadingAccountBalance)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" />
                                    }
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.caption" Style="opacity:0.8;">Account Balance:</MudText>
                                        <MudText Typo="Typo.body1" Style="font-weight:700;">@accountBalance.Value.ToString("n0")</MudText>
                                    </MudStack>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudStack>
                </MudItem>

                <MudItem xs="12"><MudDivider Class="my-2" /></MudItem>

                <MudItem xs="12">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                        <MudDivider Vertical="true" FlexItem="true" Style="border-width: 3px; border-color: #057a52; height: 16px; border-radius: 2px;" />
                        <MudText Typo="Typo.caption" Style="color:#057a52; font-weight:900; letter-spacing:.1em;">RECIPIENT & NOTES</MudText>
                    </MudStack>

                    <MudGrid Spacing="2">
                        <MudItem xs="7">
                            <MudTextField T="string" Label="Paid To" @bind-Value="Model.PaidTo"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" AdornmentColor="Color.Primary" />
                        </MudItem>
                        <MudItem xs="5">
                            <MudTextField T="string" Label="Description" @bind-Value="Model.Description"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3"
                                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Description" AdornmentColor="Color.Primary" />
                        </MudItem>
                    </MudGrid>
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>

      <DialogActions>
        <MudStack Row="true" Class="px-4 pb-4" Style="width: 100%;">
            <MudButton Variant="Variant.Filled" 
                       OnClick="OnValidSubmit" 
                       StartIcon="@Icons.Material.Filled.Save"
                       FullWidth="true"
                       Style="background-color: #023d28; color: white; border-radius: 8px; padding: 12px 0; font-weight: 700;">
                SAVE EXPENSE
            </MudButton>
        </MudStack>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; }

    private CreateExpenseDTO Model = new();
    private decimal? remaining;
    private decimal? accountBalance;

    private bool isLoadingBudget = false;

    private bool isLoadingAccountBalance;

    private bool ShowErrors;
     private bool _isProcessing;
    private List<Account> _accounts = new();
    private List<ExpenseType> ExpenseTypes = new();
    
    
    
    protected override async Task OnInitializedAsync()
    {
        _accounts = await AccountService.GetAllAccountsAsync();

        ExpenseTypes = await ExpenseTypeService.GetAllExpenseTypesAsync();
        // Initialize date if null
        if (Model.Date == null) Model.Date = DateTime.Today;

        // Fetch types for the current month
        await LoadExpenseTypesByMonth(Model.Date.Value);
    }

        private async Task OnValidSubmit()
    {
        _isProcessing = true;
        ShowErrors = false;
        
        try 
        {
            await ExpenseService.CreateExpenseAsync(Model);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
           
            ShowErrors = true;
        }
        finally
        {
            _isProcessing = false;
        }
        
    
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task GoToCreateExpenseType()
    {
        var option = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<CreateExpenseTypeDialog>("Create Expense Type", new DialogParameters {
            { "OnExpenseTypeCreated", EventCallback.Factory.Create(this, async () => {
                ExpenseTypes = await ExpenseTypeService.GetAllExpenseTypesAsync();
                StateHasChanged();
            })}
        }, option);
    }

     private async Task OnExpenseTypeChanged(int newValue)
    {
        Model.ExpenseTypeId = newValue;
        await CalculateRemainingBudget();
    }

      private async Task CalculateRemainingBudget()
    {
        if (Model.ExpenseTypeId <= 0 || !Model.Date.HasValue) {
            remaining = null;
            return;
        }
        isLoadingBudget = true;
        try { remaining = await ExpenseService.GetRemainingBudgetAsync(Model.ExpenseTypeId, Model.Date.Value); }
        catch { remaining = null; }
        finally { isLoadingBudget = false; }
    }

    private async Task OnDateChanged()
    {
        var date = Model.Date ?? DateTime.Today;
        await LoadExpenseTypesByMonth(date);
        if (Model.ExpenseTypeId > 0) await CalculateRemainingBudget();
    }


    private async Task OnAccountChanged(int value)
    {
        Model.AccountId = value;
        await CalculateAccountBalance();
    }

    private async Task CalculateAccountBalance()
    {
        if (Model.AccountId <= 0) { accountBalance = null; return; }
        isLoadingAccountBalance = true;
        var account = _accounts.FirstOrDefault(a => a.Id == Model.AccountId);
        accountBalance = account?.Balance;
        isLoadingAccountBalance = false;
    }

    private async Task LoadExpenseTypesByMonth(DateTime date)
    {
        ExpenseTypes = await ExpenseTypeService.GetExpenseTypesByMonthAsync(date.Month, date.Year);
        if (!ExpenseTypes.Any(t => t.Id == Model.ExpenseTypeId))
        {
            Model.ExpenseTypeId = 0;
            remaining = null;
        }
    }
}