@page "/budgets"
@layout Layout.MainLayout
@using Application.DTO.Budget
@using Application.Services.BudgetServices
@using System.ClientModel
@inject IBudgetService BudgetService
@inject IDialogService DialogService
@inject IDialogService Dialog
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudDataGrid T="GetBudgetDTO" 
                 Items="@_budgets" 
                 MultiSelection="true" 
                 SortMode="SortMode.Multiple" 
                 Filterable="true"
                 Hideable="true" 
                 RowClick="@RowClicked" 
                 SelectedItemsChanged="@SelectedItemsChanged">
        
        <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Budgets</MudText>
            <MudSpacer />
            <MudMenu Label="Add Budget" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="@OpenDialogAsync">Single</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
            </MudMenu>
        </ToolBarContent>

        <Columns>
            <SelectColumn T="GetBudgetDTO" />
            <PropertyColumn Property="x => x.Id" Title="ID" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" />
            <PropertyColumn Property="x => x.Name" SortBy="@_sortBy" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" />
            <PropertyColumn Property="x => x.Status" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" />
            <PropertyColumn Property="x => x.StartingAt" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" />
            <PropertyColumn Property="x => x.EndingAt" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" />
            
            <TemplateColumn Title="Actions" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap">
                <CellTemplate>
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true">
                        @* Ensure the method name here matches exactly what is in @code *@
                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => HandleEdit(context.Item))">Edit</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error">Delete</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.MonetizationOn" 
                                    IconColor="Color.Info" 
                                    OnClick="@(() => OpenPlaning(context.Item.Id, context.Item.Name))">
                            Add Plannings
                        </MudMenuItem>
                    </MudMenu>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="GetBudgetDTO" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
    private readonly DialogOptions _closeButton = new() { CloseButton = true };
    private List<GetBudgetDTO> _budgets = new();
    private bool _sortNameByLength = false;
    private Func<GetBudgetDTO, object> _sortBy => x => 
    {
        if (_sortNameByLength)
            return (object)x.Name.Length;
        return (object)x.Name;
    };

    protected override async Task OnInitializedAsync()
    {
        _budgets = await BudgetService.GetBudgetsAsync() ?? new List<GetBudgetDTO>();
    }
    private async Task LoadBudgets()
    {
        _budgets = await BudgetService.GetBudgetsAsync() ?? new List<GetBudgetDTO>();

    }

    // Fix for CS0103: Explicitly defined handler
    private void HandleEdit(GetBudgetDTO item)
    {
        Snackbar.Add($"Editing: {item.Name}", Severity.Info);
    }
private async Task OpenPlaning(int budgetId, string budgetName)
{
    var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };

    var parameters = new DialogParameters
    {
        { "BudgetId", budgetId},
        {"BudgetName", budgetName }
    };

    var dialog = await DialogService.ShowAsync<AddPlanning>($"Planning for {budgetName}", parameters, options);
    var result = await dialog.Result;

}
private async Task OpenDialogAsync()
{
    DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

    var dialog = await DialogService.ShowAsync<AddBudget>("Add Budget", options);
    var result = await dialog.Result;

    if (result != null && !result.Canceled)
    {
        await Task.Delay(50);
        await LoadBudgets();
    }
} 


    private void RowClicked(DataGridRowClickEventArgs<GetBudgetDTO> args) { }
    private void SelectedItemsChanged(HashSet<GetBudgetDTO> items) { }
}