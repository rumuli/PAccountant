@using Domain.Entities
@using Application.Services.Accounts
@using System.Globalization

@inject NavigationManager NavigationManager

 <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="BackToAccounts" StartIcon="@Icons.Material.Filled.ArrowBack">
                    Back to Campaigns
                </MudButton>
<MudDialog>
    
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2"/> Account Details
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_account == null)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudTextField Label="Account ID" Value="@_account.Id" ReadOnly Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField Label="Type" Value="@(_account.AccountType?.Name)" ReadOnly Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="Account Number" Value="@_account.AccountNumber" ReadOnly Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="Balance" Value="@_account.Balance.ToString("C")" ReadOnly Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudChip T="string" Color="@GetStatusColor(_account.Status)">@_account.Status</MudChip>
                </MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public int Id { get; set; } 
    
    [Inject] IAccountService AccountService { get; set; }

    private Account _account;

    protected override async Task OnInitializedAsync()
    {
        _account = await AccountService.GetAcountById(Id);
    }

    private void Close() => MudDialog.Close();

    private Color GetStatusColor(string status) => status?.ToLower() switch
    {
        "active" => Color.Success,
        "inactive" => Color.Error,
        _ => Color.Default
    };
     private void BackToAccounts()
    {
        NavigationManager.NavigateTo("/Accounts");
    }
}