@using Application.DTO
@using Application.Services.Accounts
@using Application.Services.Incomes
@using Application.Services.IncomeTypes
@using Application.Services.PaymentMethods
@using MudBlazor
@using System.ComponentModel.DataAnnotations
@using Domain.Entities
@using Microsoft.EntityFrameworkCore

@inject IIncomeService IncomeService
@inject IIncomeTypeService IncomeTypeService
@inject IAccountService AccountService
@inject IPaymentMethodService PaymentMethodService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService

<MudDialog Style="border-radius:16px; overflow:hidden; max-width: 750px;">
    <DialogContent>
        <MudPaper Elevation="0" 
                  Class="pa-5 mb-6" 
                  Style="background: linear-gradient(90deg, #023d28 0%, #057a52 100%); border-radius:12px; color:white; position:relative; overflow:hidden;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                <MudAvatar Color="Color.Default" Style="height:60px; width:60px; background: rgba(255,255,255,0.2);">
                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Style="font-size:2.5rem; color: white;" />
                </MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6" Style="font-weight:700;">New Income Record</MudText>
                    <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.8);">Fill in the details below to create an entry</MudText>
                </MudStack>
            </MudStack>
            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" 
                     Style="position:absolute; right:-10px; bottom:-10px; font-size:6rem; color:rgba(255,255,255,0.1);" />
        </MudPaper>

        <EditForm Model="Model" OnValidSubmit="OnValidSubmit">
            <DataAnnotationsValidator />

            <MudGrid Spacing="3">
                <MudItem xs="12" sm="7">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                        <MudDivider Vertical="true" FlexItem="true" Style="border-width: 3px; border-color: #057a52; height: 16px; border-radius: 2px;" />
                        <MudText Typo="Typo.caption" Style="color:#057a52; font-weight:900; letter-spacing:.1em;">CLASSIFICATION</MudText>
                    </MudStack>

                    <MudStack Spacing="3">
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudSelect T="int" Label="Income Type" @bind-Value="Model.IncomeTypeId"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                                       AdornmentIcon="@Icons.Material.Filled.Category" Adornment="Adornment.Start" AdornmentColor="Color.Primary">
                                <MudSelectItem Value="0">— Select Income Type</MudSelectItem>
                                @foreach (var type in IncomeTypes) { <MudSelectItem Value="@type.Id">@type.IncomeTypeName</MudSelectItem> }
                            </MudSelect>
                            @* <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Variant="Variant.Outlined" 
                                           Size="Size.Small" OnClick="@GoToCreateIncomeType" Style="height:40px; width:40px;" /> *@
                        </MudStack>

                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudSelect T="int" Label="Payment Method" @bind-Value="Model.PaymentMethodId"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                                       AdornmentIcon="@Icons.Material.Filled.CreditCard" Adornment="Adornment.Start" AdornmentColor="Color.Primary">
                                <MudSelectItem Value="0">— Select Payment Method</MudSelectItem>
                                @foreach (var method in PaymentMethods) { <MudSelectItem Value="@method.Id">@method.PaymentMethodName</MudSelectItem> }
                            </MudSelect>
                            @* <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Variant="Variant.Outlined" 
                                           Size="Size.Small" OnClick="@GoToCreatePaymentMethod" Style="height:40px; width:40px;" /> *@
                        </MudStack>
                    </MudStack>
                </MudItem>

                <MudItem xs="12" sm="5">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                        <MudDivider Vertical="true" FlexItem="true" Style="border-width: 3px; border-color: #057a52; height: 16px; border-radius: 2px;" />
                        <MudText Typo="Typo.caption" Style="color:#057a52; font-weight:900; letter-spacing:.1em;">FINANCIAL DETAILS</MudText>
                    </MudStack>

                    <MudStack Spacing="3">
                        <MudTextField T="decimal" Label="Amount Paid" @bind-Value="Model.AmountPaid"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"/>
                                      @* Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" AdornmentColor="Color.Primary" /> *@
                        
                        <MudDatePicker Label="Income Date" @bind-Value="Model.Date"
                                       Variant="Variant.Outlined" Margin="Margin.Dense"
                                       Adornment="Adornment.Start" AdornmentColor="Color.Primary" />
                    </MudStack>
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                </MudItem>

                <MudItem xs="12">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                        <MudDivider Vertical="true" FlexItem="true" Style="border-width: 3px; border-color: #057a52; height: 16px; border-radius: 2px;" />
                        <MudText Typo="Typo.caption" Style="color:#057a52; font-weight:900; letter-spacing:.1em;">ACCOUNT INFORMATION</MudText>
                    </MudStack>

                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="7">
                            <MudTextField T="string" Label="Source" @bind-Value="Model.Source"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          Placeholder="e.g. Salary, Freelance, Bonus..."
                                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Description" AdornmentColor="Color.Primary" />
                        </MudItem>
                        <MudItem xs="12" sm="5">
                            <MudSelect T="int" Label="Account" @bind-Value="Model.AccountId"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                                       Required="true" AdornmentIcon="@Icons.Material.Filled.AccountBalance" Adornment="Adornment.Start" AdornmentColor="Color.Primary">
                                       <MudSelectItem Value="0">Select Account</MudSelectItem>
                                @foreach (var account in _accounts) { <MudSelectItem Value="@account.Id">@account.AccountNumber</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>

   <DialogActions>
    <MudStack Row="true" Spacing="0" Class="px-4 pb-4" Style="width: 100%;">
        <MudButton Variant="Variant.Filled" 
                   OnClick="OnValidSubmit" 
                   StartIcon="@Icons.Material.Filled.Save"
                   FullWidth="true"
                   Style="background-color: #023d28; color: white; border-radius: 8px; padding: 12px 0; font-weight: 700; height: 50px;">
            SAVE INCOME
        </MudButton>
    </MudStack>
</DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; }
    @* [Parameter] public EventCallback OnIncomeCreated { get; set; } *@

    private CreateIncomeDTO Model { get; set; } = new();
    private List<Account> _accounts = new();
    private List<IncomeType> IncomeTypes = new();
    private List<PaymentMethod> PaymentMethods = new();
    private bool ShowErrors { get; set; } = false;
    private bool _isProcessing { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _accounts = await AccountService.GetAllAccountsAsync();
        IncomeTypes = await IncomeTypeService.GetAllIncomeTypesAsync();
        PaymentMethods = await PaymentMethodService.GetAllPaymentMethodsAsync();
        if (Model.Date == null) Model.Date = DateTime.Today;
    }

    private async Task OnValidSubmit()
    {
        _isProcessing = true;
        ShowErrors = false;

        try 
        {
            await IncomeService.CreateIncomeAsync(Model);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch
        {
            ShowErrors = true;
        }
        finally
        {
            _isProcessing = false;
        }
        }

    private void Cancel() => MudDialog.Cancel(); 

    private async Task GoToCreateIncomeType()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<CreateIncomeTypeDialog>("Create Income Type", new DialogParameters {
            { "OnIncomeTypeCreated", EventCallback.Factory.Create(this, async () => {
                IncomeTypes = await IncomeTypeService.GetAllIncomeTypesAsync();
                StateHasChanged();
            })}
        }, options);
    }

    private async Task GoToCreatePaymentMethod()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<CreatePaymentMethodDialog>("Create Payment Method", new DialogParameters {
            { "OnPaymentMethodCreated", EventCallback.Factory.Create(this, async () => {
                PaymentMethods = await PaymentMethodService.GetAllPaymentMethodsAsync();
                StateHasChanged();
            })}
        }, options);
    }
}