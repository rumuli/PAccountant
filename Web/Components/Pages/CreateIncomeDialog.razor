@using Application.DTO
@using Application.Services.Incomes
@using Application.Services.IncomeTypes
@using Application.Services.PaymentMethods
@using MudBlazor
@using System.ComponentModel.DataAnnotations
@inject IIncomeService IncomeService
@inject IIncomeTypeService IncomeTypeService
@inject IPaymentMethodService PaymentMethodService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@using Domain.Entities
@using Infrastructure.Data
@using Microsoft.EntityFrameworkCore




<MudDialog Style="border-radius:12px; overflow:hidden;">

    <!-- ══════════ HEADER BANNER ══════════ -->
    <DialogContent>
        <MudPaper Elevation="0"
                  Style="background: linear-gradient(135deg, #1976D2 0%, #42A5F5 100%);
                         border-radius:8px; padding:14px 18px; margin-bottom:16px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.AttachMoney"
                         Style="color:white; font-size:1.6rem;" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1"
                             Style="color:white; font-weight:700; line-height:1.2;">
                        New Income Record
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.80);">
                        Fill in the details below to create an entry
                    </MudText>
                </MudStack>
            </MudStack>
        </MudPaper>

        <!-- ══════════ FORM ══════════ -->
        <EditForm Model="Model" OnValidSubmit="OnValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <MudStack Spacing="1">

                <!-- ── Section: Classification ── -->
                <MudText Typo="Typo.caption"
                         Style="color:#9E9E9E; font-weight:600; letter-spacing:.08em;
                                text-transform:uppercase; margin-bottom:2px;">
                    Classification
                </MudText>

                <!-- Income Type -->
                <MudGrid Spacing="1" Class="align-items-center">
                    <MudItem xs="11">
                        <MudSelect T="int"
                                   Label="Income Type"
                                   @bind-Value="Model.IncomeTypeId"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Dense="true"
                                   AnchorOrigin="Origin.BottomCenter"
                                   AdornmentIcon="@Icons.Material.Filled.Category"
                                   Adornment="Adornment.Start"
                                   AdornmentColor="Color.Primary">
                            <MudSelectItem Value="0">— Select Income Type</MudSelectItem>
                            @foreach (var type in IncomeTypes)
                            {
                                <MudSelectItem Value="@type.Id">@type.IncomeTypeName</MudSelectItem>
                            }
                        </MudSelect>
                        <ValidationMessage For="@(() => Model.IncomeTypeId)" />
                    </MudItem>
                    <MudItem xs="1" Class="d-flex justify-center">
                        <MudTooltip Text="Add new income type">
                            <MudIconButton Icon="@Icons.Material.Filled.Add"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Variant="Variant.Outlined"
                                           OnClick="@GoToCreateIncomeType" />
                        </MudTooltip>
                    </MudItem>
                </MudGrid>

                <!-- Payment Method -->
                <MudGrid Spacing="1" Class="align-items-center">
                    <MudItem xs="11">
                        <MudSelect T="int"
                                   Label="Payment Method"
                                   @bind-Value="Model.PaymentMethodId"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Dense="true"
                                   AnchorOrigin="Origin.BottomCenter"
                                   AdornmentIcon="@Icons.Material.Filled.Payment"
                                   Adornment="Adornment.Start"
                                   AdornmentColor="Color.Primary">
                            <MudSelectItem Value="0">— Select Payment Method</MudSelectItem>
                            @foreach (var method in PaymentMethods)
                            {
                                <MudSelectItem Value="@method.Id">@method.PaymentMethodName</MudSelectItem>
                            }
                        </MudSelect>
                        <ValidationMessage For="@(() => Model.PaymentMethodId)" />
                    </MudItem>
                    <MudItem xs="1" Class="d-flex justify-center">
                        <MudTooltip Text="Add new payment method">
                            <MudIconButton Icon="@Icons.Material.Filled.Add"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Variant="Variant.Outlined"
                                           OnClick="@GoToCreatePaymentMethod" />
                        </MudTooltip>
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-2" />

                <!-- ── Section: Financial Details ── -->
                <MudText Typo="Typo.caption"
                         Style="color:#9E9E9E; font-weight:600; letter-spacing:.08em;
                                text-transform:uppercase; margin-bottom:2px;">
                    Financial Details
                </MudText>

                <!-- Amount + Date side-by-side -->
                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudTextField T="decimal"
                                      Label="Amount Paid"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      @bind-Value="Model.AmountPaid"
                                      Placeholder="0.00"
                                      InputType="InputType.Number"
                                     
                                      For="@(() => Model.AmountPaid)" />
                        <ValidationMessage For="@(() => Model.AmountPaid)" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudDatePicker Label="Income Date"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       @bind-Value="Model.Date"
                                       Placeholder="Pick a date"
                                       Adornment="Adornment.Start"
                                       AdornmentColor="Color.Primary" />
                        <ValidationMessage For="@(() => Model.Date)" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-2" />

                <!-- ── Section: Account Info ── -->
                <MudText Typo="Typo.caption"
                         Style="color:#9E9E9E; font-weight:600; letter-spacing:.08em;
                                text-transform:uppercase; margin-bottom:2px;">
                    Account Info
                </MudText>

                <!-- Source -->
                <MudTextField T="string"
                              Label="Source"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.Source"
                              Placeholder="e.g. Salary, Freelance…"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Source"
                              AdornmentColor="Color.Primary"
                              For="@(() => Model.Source)" />
                <ValidationMessage For="@(() => Model.Source)" />


           <MudSelect T="int"
           Label="Account Type"
           @bind-Value="Model.AccountId"
           Variant="Variant.Outlined"
           Margin="Margin.Dense"
           Dense="true"
           Required="true">
    @foreach (var account in _accounts)
    {
        <MudSelectItem Value="@account.Id">@account.AccountNumber</MudSelectItem>
    }
</MudSelect>






                           
                        

            </MudStack>
        </EditForm>
    </DialogContent>

    <!-- ══════════ ACTIONS ══════════ -->
    <DialogActions>
        <MudStack Row="true" Spacing="2" Class="px-2 pb-2" Style="width:100%;">
            

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="OnValidSubmit"
                       Style="flex:2; border-radius:8px;
                              background: linear-gradient(135deg,#1976D2,#42A5F5);">
                Save Income
            </MudButton>
        </MudStack>
    </DialogActions>

</MudDialog>

@code {
    
  private List<Account> _accounts = new();

    // Inject DbContext
    [Inject] private ApplicationDbContext _dbContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        @* _accounts = await _dbContext.AccountTypes.ToListAsync(); *@
            // Load AccountTypes directly from DbContext
    _accounts = await _dbContext.Accounts.ToListAsync();

    // Load IncomeTypes from service
    IncomeTypes = await IncomeTypeService.GetAllIncomeTypesAsync();

    // Load PaymentMethods from service
    PaymentMethods = await PaymentMethodService.GetAllPaymentMethodsAsync();
    }




    [CascadingParameter]
    private IDialogReference DialogReference { get; set; } = default!;

    private CreateIncomeDTO Model { get; set; } = new();

    [Parameter]
    public EventCallback OnIncomeCreated { get; set; }

    private bool ShowErrors { get; set; } = false;

    private List<IncomeType> IncomeTypes = new();
    private List<PaymentMethod> PaymentMethods = new();







    private async Task OnValidSubmit()
    {
        try
        {
            await IncomeService.CreateIncomeAsync(Model);
            await OnIncomeCreated.InvokeAsync();
            DialogReference.Close(DialogResult.Ok(true));
        }
        catch
        {
            ShowErrors = true;
        }

        NavigationManager.NavigateTo("/incomes");
    }

    private void Cancel()
    {
        DialogReference.Close(DialogResult.Cancel());
    }

    private async Task GoToCreateIncomeType()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<CreateIncomeTypeDialog>(
            "Create Income Type",
            new DialogParameters
            {
                { "OnIncomeTypeCreated", EventCallback.Factory.Create(this, async () =>
                    {
                        IncomeTypes = await IncomeTypeService.GetAllIncomeTypesAsync();
                        StateHasChanged();
                    })
                }
            },
            options
        );
    }

    private async Task GoToCreatePaymentMethod()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<CreatePaymentMethodDialog>(
            "Create Payment Method",
            new DialogParameters
            {
                { "OnPaymentMethodCreated", EventCallback.Factory.Create(this, async () =>
                    {
                        PaymentMethods = await PaymentMethodService.GetAllPaymentMethodsAsync();
                        StateHasChanged();
                    })
                }
            },
            options
        );
    }
}