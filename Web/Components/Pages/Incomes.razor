@page "/incomes"
@using Domain.Entities
@using Application.Services.Incomes
@using MudBlazor
@inject IIncomeService IncomeService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

@* <PageTitle>Incomes</PageTitle> *@

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">

    <MudGrid Class="mb-4">
        @* Left Section: Portfolio Overview (Reduced Height & Padding) *@
        <MudItem xs="12" md="8">
            <MudPaper Elevation="0" Class="pa-5 d-flex flex-column relative overflow-hidden" 
                      Style="min-height: 10px; border-radius: 16px; background: linear-gradient(135deg, #ffffff 0%, #f5f7fa 100%); border: 1px solid #e0e0e0;">
                
                <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" 
                         Style="position:absolute; right:-10px; top:-10px; font-size:7rem; color:rgba(25, 118, 210, 0.05);" />
                
                <MudText Typo="Typo.subtitle1" Style="font-weight: 800; color: #023d28;">Income Gained</MudText>
                
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-1">
                    <MudText Typo="Typo.h4" Style="font-weight: 900; color: #023d28;">
                        @_incomes.Sum(x => x.AmountPaid).ToString("n")
                    </MudText>
                    <MudChip T="string" Color="Color.Success" Variant="Variant.Text" Size="Size.Small" Icon="@Icons.Material.Filled.NorthEast">Total Gained</MudChip>
                </MudStack>

                <MudDivider Class="my-2" />

                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1" Style="font-weight:700; text-transform:uppercase;">Account Breakdown</MudText>
                
                <div class="d-flex flex-wrap gap-2">
                    @if (_incomes != null && _incomes.Any())
                    {
                        @foreach (var group in _incomes.GroupBy(x => x.Account?.AccountNumber ?? "Other"))
                        {
                            <MudPaper Elevation="0" Class="px-3 py-1" 
                                      Style="background: white; border: 1px solid #e0e0e0; border-radius: 10px; min-width: 130px; flex-grow: 1; max-width: 180px;">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Style="font-weight:bold; color: #023d28; font-size: 0.7rem;">@group.Key</MudText>
                                    <MudText Typo="Typo.subtitle2" Style="font-weight:800; color: #023d28;">@group.Sum(x => x.AmountPaid).ToString("n")</MudText>
                                </MudStack>
                            </MudPaper>
                        }
                    }
                </div>
            </MudPaper>
        </MudItem>

         @* 3. Total Transactions Card (Dark Green) *@
        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="pa-6 d-flex flex-column justify-center align-center" 
                      Style="height: 160px; border-radius: 20px; background: #023d28; color: white; position: relative; overflow: hidden;">

       <div style="position: absolute; bottom: -20px; left: -20px; opacity: 0.1;">
                     <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Style="font-size: 100px; color: white;" />
                </div>
        
                 <MudText Typo="Typo.caption" Style="opacity: 0.9; text-transform: uppercase; font-weight: 700; letter-spacing: 1.5px; z-index: 1;">
                    Total Income records
                </MudText>
                <MudText Typo="Typo.h2" Style="font-weight: 900; z-index: 1;">@_incomes.Count</MudText>    
             </MudPaper>   
               
        </MudItem>
    </MudGrid>

    @* --- DATA GRID (UNTOUCHED LOGIC) --- *@
    <MudDataGrid T="Income"
                 Items="@_incomes"
                 MultiSelection="true"
                 SortMode="SortMode.Multiple"
                 Filterable="true"
                 Hideable="true"
                 Dense="true"
                 Hover="true"
                 Striped="true"
                 Bordered="true"
                 Class="elevation-1">
        <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Incomes</MudText>
            <MudSpacer />
            <MudMenu Label="Add Income" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="GoToCreateIncome">Single</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
            </MudMenu>
        </ToolBarContent>
        <Columns>
            <SelectColumn T="Income" />
            <PropertyColumn Property="x => x.Id" Title="ID" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.IncomeType.IncomeTypeName" Title="Income Type" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.Date" Title="Date" Format="dd MMM yyyy" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.AmountPaid" Title="Amount Paid" Format="n" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.Source" Title="Source" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <PropertyColumn Property="x => x.Account.AccountNumber" Title="Deposited Account" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" Sortable="true" />
            <TemplateColumn Title="Status">
                <CellTemplate>
                    <MudChip T="string" Color="@(context.Item.IsActive ? Color.Success : Color.Error)" Size="Size.Small" Variant="Variant.Text">
                        @(context.Item.IsActive ? "Active" : "Inactive")
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Actions">
                <CellTemplate>
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true" Size="Size.Small">
                        <MudMenuItem Icon="@Icons.Material.Filled.Info" OnClick="@(() => Snackbar.Add($"Viewing {context.Item.Id}", Severity.Info))">Details</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => Snackbar.Add($"Editing {context.Item.Id}", Severity.Info))">Edit</MudMenuItem>
                    </MudMenu>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="Income" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
    private List<Income> _incomes = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadIncomes();
    }

    private async Task LoadIncomes()
    {
        _incomes = await IncomeService.GetAllIncomesAsync();
        StateHasChanged();
    }

    private async Task GoToCreateIncome()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateIncomeDialog>("Add Income", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(100);
            await LoadIncomes();
        }
    }

    private List<ChartSeries> _series = new() 
    { 
        new ChartSeries { Name = "Activity", Data = new double[] { 12, 45, 30, 60, 40, 80, 50 } } 
    };

    private ChartOptions _chartOptions = new() { InterpolationOption = InterpolationOption.Straight };
}