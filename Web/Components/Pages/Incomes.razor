@page "/incomes"
@using Domain.Entities
@using Application.Services.Incomes
@using MudBlazor
@inject IIncomeService IncomeService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Incomes</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudDataGrid T="Income"
                 Items="@_incomes"
                 Hover="true"
                 Striped="true"
                 Bordered="true"
                 Dense="true"
                 Filterable="true"
                 SortMode="SortMode.Multiple"
                 Class="elevation-1">

        <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Income</MudText>
            <MudSpacer />
            <MudMenu Label="Add Income" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">Single</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
            </MudMenu>
        </ToolBarContent>

        <Columns>
            <SelectColumn T="Income" />

            <PropertyColumn Property="x => x.Id"
                            Title="ID"
                            HeaderStyle="white-space:nowrap"
                            ItemStyle="white-space:nowrap"
                            Sortable="true" />

            <PropertyColumn Property="x => x.IncomeType.IncomeTypeName"
                            Title="Income Type"
                            HeaderStyle="white-space:nowrap"
                            ItemStyle="white-space:nowrap"
                            Sortable="true" />

            <PropertyColumn Property="x => x.Date"
                            Title="Date"
                            Format="dd MMM yyyy"
                            ItemStyle="white-space:nowrap"
                            HeaderStyle="white-space:nowrap"
                            Sortable="true" />

            <PropertyColumn Property="x => x.AmountPaid"
                            Title="Amount Paid"
                            Format="C"
                            ItemStyle="white-space:nowrap"
                            HeaderStyle="white-space:nowrap"
                            Sortable="true" />

            <PropertyColumn Property="x => x.Source"
                            Title="Source"
                            ItemStyle="white-space:nowrap"
                            HeaderStyle="white-space:nowrap"
                            Sortable="true" />

            <PropertyColumn Property="x => x.PaymentMethod.PaymentMethodName"
                            Title="Payment Method"
                            ItemStyle="white-space:nowrap"
                            HeaderStyle="white-space:nowrap"
                            Sortable="true" />

            <PropertyColumn Property="x => x.DepositedAccount"
                            Title="Deposited Account"
                            ItemStyle="white-space:nowrap"
                            HeaderStyle="white-space:nowrap"
                            Sortable="true" />

            <TemplateColumn Title="Status">
                <CellTemplate>
                    <MudChip T="string"
                             Color="@(context.Item.IsActive ? Color.Success : Color.Error)"
                             Text="@(context.Item.IsActive ? "Active" : "Inactive")"
                             Variant="Variant.Filled"
                             ItemStyle="white-space:nowrap"
                             HeaderStyle="white-space:nowrap"
                             Size="Size.Small" />
                </CellTemplate>
            </TemplateColumn>

            <PropertyColumn Property="x => x.CreatedAt"
                            Title="Created Date"
                            Format="MM/dd/yyyy"
                            ItemStyle="white-space:nowrap"
                            HeaderStyle="white-space:nowrap"
                            Sortable="true" />

            <!-- Actions -->
            <TemplateColumn Title="Actions">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Info"
                                   Color="Color.Info"
                                   Size="Size.Small"
                                   OnClick="@(() => ViewIncome(context.Item.Id))"
                                   Title="View Details" />

                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   OnClick="@(() => EditIncome(context.Item.Id))"
                                   Title="Edit Income" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
</MudContainer>

@code {
    private List<Income> _incomes = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadIncomes();
    }

    private async Task OpenCreateDialog()
    {
        var option = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<CreateIncomeDialog>(title: "Create Income", new DialogParameters()
        {
            { "OnIncomeCreated", EventCallback.Factory.Create(this, LoadIncomes) }
        }, option);
    }

    private async Task LoadIncomes()
    {
        _incomes = await IncomeService.GetAllIncomesAsync();
        StateHasChanged();
    }

    private void ViewIncome(int id)
    {
        Snackbar.Add($"Viewing details for Income ID {id}", Severity.Info);
        // Navigate or open dialog for details
    }

    private void EditIncome(int id)
    {
        Snackbar.Add($"Editing Income ID {id}", Severity.Normal);
        // Navigate or open dialog for editing
    }
}

