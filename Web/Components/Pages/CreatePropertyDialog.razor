@code{
    private bool _fullWidth;
    private bool _fitContent;
    [CascadingParameter] IMudDialogInstance DialogInstance { get; set; }
    [SupplyParameterFromForm(Name = "CreatePropertyForm")]
    private PropertyCreateDTO Model {get;set;} = new ();

    [Parameter]
    public EventCallback OnPropertyCreated { get; set; }
    private async Task onValidSubmit()
    {
        await PropertyService.CreateProperty(Model);
        Snackbar.Add("Property created successfully!", Severity.Success);
        DialogInstance.Close();
        await PropertyService.GetAllPropertysAsync();
    }

    private async Task openCategory()
    {
        var dialog = await DialogService.ShowAsync<PropertyCategoryDialog>("Add Category");
        var result = await dialog.Result;
    } 

private List<PropertyCategory> acctype = new List<PropertyCategory>();

protected override async Task OnInitializedAsync()
{
    try 
    {
       
        var types = await PropertyCategoryService.GetAllPropertyCategorysAsync();
       if (types != null)
        {
            acctype = types;
        }
    }
    catch (Exception ex)
    {
        Snackbar.Add("Error loading account types", Severity.Error);
    }
}
// person///////////////////
private List<Person> person = new List<Person>();

protected override void OnInitialized()
{
    try 
    {
        var typess =  PersonService.GetAllPersons();
       if (typess != null)
        {
            person = typess;
        }
    }
    catch (Exception ex)
    {
        Snackbar.Add("Error loading person types", Severity.Error);
    }
}
    }


