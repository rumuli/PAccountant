@using  Application.DTO
@using System.ComponentModel.DataAnnotations
@using Application.Interfaces
@using Application.Services.Persons
@using Application.Services.PropertyCategories
@using Application.Services.Properties
@using Domain.Entities
@using MudBlazor
@using MudBlazor.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@using Microsoft.AspNetCore.Authorization
@* @attribute [Authorize] *@
@inject NavigationManager Navigation
@inject IPropertyService PropertyService
@inject IPersonService PersonService
@inject IPropertycategoryService PropertyCategoryService
@inject ISnackbar Snackbar
@inject IDialogService DialogService


<MudDialog>
<DialogContent>
   
    <MudPaper Elevation="0" 
                  Style="background: linear-gradient(135deg, #023d28 0%, #4bf5ba 100%);
                         padding:14px 18px; margin-bottom:16px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">

                <MudIcon Icon="@Icons.Material.Filled.HomeWork"
                         Style="color:white; font-size:1.6rem;" />

                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1"
                             Style="color:white; font-weight:700; line-height:1.2;">
                        Create Account
                    </MudText>

                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.80);">
                        Fill the form below to create a new account
                    </MudText>
                </MudStack>
            </MudStack>
    </MudPaper>

    <EditForm Model="Model" OnValidSubmit="onValidSubmit" FormName="CreatePropertyForm">
        <DataAnnotationsValidator />
        <MudGrid  Spacing="1" Class="align-items-center">
             
    <MudItem xs="6">
    <MudSelect T="int"
               Label="Category" 
               Placeholder="--Select Category Type--"
               @bind-Value="Model.CategoryId" 
               Variant="Variant.Outlined"
                Dense="true"
               Margin="Margin.Dense"
               AdornmentIcon="@Icons.Material.Filled.Category"
               AdornmentColor="Color.Primary">

               <MudSelectItem Value="0">--Select Category Type--</MudSelectItem>
         @if (acctype != null)
        {
            foreach (var type in acctype)
            {
                <MudSelectItem T="int" Value="@type.Id">@type.Name</MudSelectItem>
            }
        }
    </MudSelect>
    </MudItem>
            <MudItem xs="6">
                <MudTextField Label="Name/Manufacturer" Variant="Variant.Outlined" Margin="Margin.Dense"@bind-Value="Model.Manufacturer" For="@(() => Model.Manufacturer)" />
            </MudItem>
    <MudItem xs="12">
        
                <!-- SECTION : PROPERTY INFO -->
                <MudText Typo="Typo.caption"
                         Style="color:#9E9E9E; font-weight:600;
                         letter-spacing:.08em; text-transform:uppercase;">
                    Property Information
                </MudText>
    </MudItem>
            <MudItem xs="6">
                <MudTextField Label="Name/Model" Variant="Variant.Outlined" Margin="Margin.Dense"@bind-Value="Model.Name" For="@(() => Model.Name)" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField Label="Value" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="Model.Value" For="@(() => Model.Value)" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField Label="Location" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="Model.Location" For="@(() => Model.Location)" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField Label="AssignedTo"  Variant="Variant.Outlined" Margin="Margin.Dense"@bind-Value="Model.AssignedTo" For="@(() => Model.AssignedTo)" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField Label="PurchasePrice" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="Model.PurchasePrice" For="@(() => Model.PurchasePrice)" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField Label="Identification" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="Model.Identification" For="@(() => Model.Identification)" />
            </MudItem>            
            <MudItem xs="12" class="d-flex justify-content-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" ButtonType="ButtonType.Submit">Add property</MudButton>
            </MudItem>
        </MudGrid>

    </EditForm>
</DialogContent>
</MudDialog>
