@using Application.Services.Accounts
@using Domain.Entities
@using Application.DTO
@using Application.Interfaces
@using MudBlazor
@inject IAccountService AccountService
@inject IAccountTypeService AccountTypeService
@inject ISnackbar Snackbar

@rendermode InteractiveServer

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2"/> Edit Account Asset
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_accountTypes == null)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <EditForm Model="@_editModel" OnValidSubmit="OnValidSubmit" FormName="EditAccountForm">
                <DataAnnotationsValidator />
                <MudStack Spacing="3">
                    
                    <MudTextField Label="Account Number" @bind-Value="_editModel.AccountNumber" 
                                  Variant="Variant.Outlined" For="@(() => _editModel.AccountNumber)" />

                    <MudTextField Label="Provider" @bind-Value="_editModel.Provider" 
                                  Variant="Variant.Outlined" For="@(() => _editModel.Provider)" />

                    <MudNumericField Label="Balance" @bind-Value="_editModel.Balance" 
                                     Variant="Variant.Outlined" For="@(() => _editModel.Balance)" />

                    <MudSelect T="string" Label="Status" @bind-Value="_editModel.Status" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Active")">Active</MudSelectItem>
                        <MudSelectItem Value="@("Inactive")">Inactive</MudSelectItem>
                    </MudSelect>

                </MudStack>
            </EditForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="OnValidSubmit">Save Changes</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public int Id { get; set; } // The ID of the account to edit

    private AccountUpdateDTO _editModel = new();
    private List<AccountType> _accountTypes;

    protected override async Task OnInitializedAsync()
    {
        // 1. Load Categories/Types for the dropdown
        _accountTypes = await AccountTypeService.GetAllAccountTypes();

        // 2. Load the existing Account data
        var account = await AccountService.GetAcountById(Id);
        if (account != null)
        {
            // Map Entity to DTO
            _editModel = new AccountUpdateDTO
            {
                AccountNumber = account.AccountNumber,
                Provider = account.Provider,
                Balance = account.Balance,
                Status = account.Status,
                UpdateBy="Admin"
            };
        }
    }

    private async Task OnValidSubmit()
    {
        try
        {
            await AccountService.UpdateAccount(Id, _editModel);
            Snackbar.Add("Asset updated successfully!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Update failed: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel() => MudDialog.Cancel();
}