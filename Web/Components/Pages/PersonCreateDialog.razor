
@using  Application.DTO
@using System.ComponentModel.DataAnnotations
@using Application.Interfaces
@using Domain.Entities
@using Application.Services.Persons
@using MudBlazor
@using MudBlazor.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject NavigationManager Navigation
@inject IPersonService PersonService
@inject ISnackbar Snackbar
@inject IDialogService DialogService


<MudDialog Style=" overflow:hidden;">

    <DialogContent>

        <!-- ══════════ HEADER ══════════ -->
        <MudPaper Elevation="0"
                  Style="background: linear-gradient(135deg, #023d28 0%, #4bf5ba 100%);
                        padding:14px 18px; margin-bottom:16px;">

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">

                <MudIcon Icon="@Icons.Material.Filled.PersonAdd"
                         Style="color:white; font-size:1.0rem;" />

                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1"
                             Style="color:white; font-weight:700;">
                        Add Person
                    </MudText>
                    <MudText Typo="Typo.caption"
                             Style="color:rgba(255,255,255,0.80);">
                        Enter personal information below
                    </MudText>
                </MudStack>
            </MudStack>
        </MudPaper>


        <!-- ══════════ FORM ══════════ -->
        <EditForm Model="Model" OnValidSubmit="onValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <MudStack Spacing="2">
                <!-- SECTION : BASIC INFO -->
                @* <MudText Typo="Typo.caption"
                         Style="color:#9E9E9E; font-weight:600;
                         letter-spacing:.08em; text-transform:uppercase;">
                    Basic Information *@
                @* </MudText> *@

               <MudGrid Spacing="1" Class="align-items-center">

                    <MudItem xs="6">
                        <MudTextField Label="First Name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      @bind-Value="Model.FirstName"
                                      For="@(() => Model.FirstName)" />
                    </MudItem>

                    <MudItem xs="6">
                        <MudTextField Label="Last Name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      @bind-Value="Model.LastName"
                                      For="@(() => Model.LastName)" />
                    </MudItem>

                    <MudItem xs="6">
                        <MudTextField Label="Sex"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      @bind-Value="Model.Sex"
                                      For="@(() => Model.Sex)" />
                    </MudItem>

                    <MudItem xs="6">
                      <MudDatePicker Label="Date Of Birth"
                       Date="Model.DateOfBirth"
                      DateChanged="@(d => Model.DateOfBirth = d ?? DateTime.Now)"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense" />
                    </MudItem>


                <!-- SECTION : CONTACT -->
              <MudItem xs="6">
                <MudTextField Label="Phone Number"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.phoneNumber"
                              For="@(() => Model.phoneNumber)"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Phone"
                              AdornmentColor="Color.Primary" />
                              </MudItem>
         <MudItem xs="6">
                <MudTextField Label="Email"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.Email"
                              For="@(() => Model.Email)"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Email"
                              AdornmentColor="Color.Primary" />
               </MudItem>
               

                    <MudItem xs="6">
                        <MudTextField Label="Country"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      @bind-Value="Model.Country"
                                      For="@(() => Model.Country)" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudTextField Label="City"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      @bind-Value="Model.City"
                                      For="@(() => Model.City)" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Label="Street"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      @bind-Value="Model.Street"
                                      For="@(() => Model.Street)" />
                    </MudItem>
                </MudGrid>
            </MudStack>
        </EditForm>
    </DialogContent>
    <DialogActions>

        <MudStack Row="true" Spacing="2" Style="width:100%;" Class="px-2 pb-2">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Save"
                       FullWidth="true"
                       ButtonType="ButtonType.Submit"
                       OnClick="onValidSubmit"
                       Style="height: 40px; font-weight: bold; margin-top:5px; margin-bottom:5px; flex:1; border-radius:8px;">

                Add Person
            </MudButton>

            @* <MudButton Href="/persons"
                       Variant="Variant.Outlined"
                       Color="Color.Error"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Cancel"
                       Style="flex:1; border-radius:8px;">

                Cancel

            </MudButton> *@

        </MudStack>
    </DialogActions>

</MudDialog>

@code{
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; }

    private void Cancel() => MudDialog.Cancel();

    private PersonCreateDTO Model {get;set;} = new ();

    @* [Parameter]
    public EventCallback OnPersonCreated { get; set; } *@
    private async Task onValidSubmit()
    {
        PersonService.CreatePerson(Model);
        Snackbar.Add("Owner created successfully!", Severity.Success);

        MudDialog.Close(DialogResult.Ok(true));

        PersonService.GetAllPersons();
    }
   

}

      
    

