
@using  Application.DTO
@using System.ComponentModel.DataAnnotations
@using Application.Interfaces
@using Domain.Entities
@using Application.Services.Persons
@using MudBlazor
@using MudBlazor.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject NavigationManager Navigation
@inject IPersonService PersonService
@inject ISnackbar Snackbar
@inject IDialogService DialogService


<MudDialog>
<DialogContent>
    <EditForm Model="Model" OnValidSubmit="onValidSubmit">
        <DataAnnotationsValidator />
        <MudGrid>
            <MudItem xs="12">
                <MudTextField Label="Name" @bind-Value="Model.FirstName" For="@(() => Model.FirstName)" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField Label="LastName" @bind-Value="Model.LastName" For="@(() => Model.LastName)" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField Label="Sex" @bind-Value="Model.Sex" For="@(() => Model.Sex)" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField Label="Status" @bind-Value="Model.Status" For="@(() => Model.Status)" />
            </MudItem>
            <MudDatePicker>
                <MudTextField Label="DateOfBirth" @bind-Value="Model.DateOfBirth" For="@(() => Model.DateOfBirth)" />
            </MudDatePicker>
           <MudItem xs="12">
                <MudTextField Label="phoneNumber" @bind-Value="Model.phoneNumber" For="@(() => Model.phoneNumber)" />
            </MudItem >
             <MudItem xs="12">
                <MudTextField Label="Email" @bind-Value="Model.Email" For="@(() => Model.Email)" />
            </MudItem>
           <MudItem xs="12">
                <MudTextField Label="Country" @bind-Value="Model.Country" For="@(() => Model.Country)" />
            </MudItem>
           <MudItem xs="12">
                <MudTextField Label="City" @bind-Value="Model.City" For="@(() => Model.City)" />
            </MudItem>
           <MudItem xs="12">
                <MudTextField Label="Street" @bind-Value="Model.Street" For="@(() => Model.Street)" />
            </MudItem>
            
            <MudItem xs="12" class="d-flex justify-content-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"  ButtonType="ButtonType.Submit" OnClick="onValidSubmit">Add persons</MudButton>
                <MudButton Href="/persons" Variant="Variant.Filled" Color="Color.Error">Cancel</MudButton>

            </MudItem>
        </MudGrid>

    </EditForm>
</DialogContent>
</MudDialog>

@code{
    [CascadingParameter] IMudDialogInstance DialogInstance { get; set; }
    private PersonCreateDTO Model {get;set;} = new ();

     [Parameter]
    public EventCallback OnPersonCreated { get; set; }
    private async Task onValidSubmit()
    {
        PersonService.CreatePerson(Model);
        Snackbar.Add("Owner created successfully!", Severity.Success);
        DialogInstance.Close();

        PersonService.GetAllPersons();
    }
   

}

      
    


