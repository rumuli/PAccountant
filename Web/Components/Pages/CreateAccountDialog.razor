@using  Application.DTO
@using System.ComponentModel.DataAnnotations
@using Application.Interfaces
@using Application.Services.Accounts
@using Application.Services.AccountTypes
@using Domain.ValueObjects

@using Domain.Entities
@using MudBlazor
@using MudBlazor.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@using Microsoft.AspNetCore.Authorization
@* @attribute [Authorize] *@
@inject NavigationManager Navigation
@inject IAccountService AccountService
@inject IAccountTypeService AccountTypeService
@inject ISnackbar Snackbar
@inject IDialogService DialogService


<MudDialog Style="overflow:hidden;">

    <DialogContent>

        <!-- ══════════ HEADER BANNER ══════════ -->
        <MudPaper Elevation="0"
                  Style="background: linear-gradient(135deg, #023d28 0%, #4bf5ba 100%);
                         padding:14px 18px; margin-bottom:16px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">

                <MudIcon Icon="@Icons.Material.Filled.AccountBalance"
                         Style="color:white; font-size:1.6rem;" />

                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1"
                             Style="color:white; font-weight:700; line-height:1.2;">
                        Create Account
                    </MudText>

                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.80);">
                        Fill the form below to create a new account
                    </MudText>
                </MudStack>

            </MudStack>
        </MudPaper>


        <!-- ══════════ FORM ══════════ -->
        <EditForm Model="Model" OnValidSubmit="onValidSubmit" FormName="CreateAccountForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

            @* <MudStack Spacing="2"> *@

                <!-- Section -->
                @* <MudText Typo="Typo.caption"
                         Style="color:#9E9E9E; font-weight:600; letter-spacing:.08em;
                                text-transform:uppercase;">
                    Account Type
                </MudText> *@

                <MudGrid Spacing="1" Class="align-items-center">

                    <MudItem xs="12">

                        <MudSelect T="int"
                                   Label="Account Type"
                                   Placeholder="--Select Account Type--"
                                   @bind-Value="Model.AccountTypeId"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Margin="Margin.Dense"
                                   AdornmentIcon="@Icons.Material.Filled.Category"
                                   AdornmentColor="Color.Primary">

                            <MudSelectItem Value="0">--Select Account Type--</MudSelectItem>

                            @if (acctype != null)
                            {
                                foreach (var type in acctype)
                                {
                                    <MudSelectItem T="int" Value="@type.Id">@type.Name</MudSelectItem>
                                }
                            }

                        </MudSelect>

                    </MudItem>

                   
                <MudItem  xs="12">
                <MudTextField Label="Account Number"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.AccountNumber"
                              For="@(() => Model.AccountNumber)" />
                </MudItem>
                <MudItem  xs="12">
                <MudTextField Label="Provider"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.Provider"
                              For="@(() => Model.Provider)" />
                </MudItem>
                <MudItem  xs="12"> 
                <MudTextField Label="Balance"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.InitialBalance"
                              For="@(() => Model.InitialBalance)"
                              InputType="InputType.Number" />
                </MudItem>
                <MudItem  xs="12">
                    <MudSelect T="AccountStatus"
                            Label="Status"
                            @bind-Value="Model.Status"
                            Variant="Variant.Outlined"
                            Dense="true"
                            Margin="Margin.Dense"
                            AdornmentIcon="@Icons.Material.Filled.Category"
                            AdornmentColor="Color.Primary">

                        <MudSelectItem T="AccountStatus">--Select Account Status--</MudSelectItem>

                        @foreach (AccountStatus status in Enum.GetValues(typeof(AccountStatus)))
                        {
                            <MudSelectItem T="AccountStatus" Value="status">@status.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                <MudButton Variant="Variant.Filled"
                        Color="Color.Primary"
                        Size="Size.Small"
                        FullWidth="true"
                        ButtonType="ButtonType.Submit"
                        Style="height: 40px; font-weight: bold; margin-top:5px; margin-bottom:5px;">
                    Add Account
                </MudButton>
                </MudItem>

            </MudGrid>

        </EditForm>
    </DialogContent>
</MudDialog>

@code{
    private bool _fullWidth;
    private bool _fitContent;
    [CascadingParameter] IMudDialogInstance DialogInstance { get; set; }
    [SupplyParameterFromForm(Name = "CreateAccountForm")]
    private AccountCreateDTO Model {get;set;} = new ();

    [Parameter]
    public EventCallback OnAccountCreated { get; set; }
    private void onValidSubmit()
    {
        AccountService.CreateAccount(Model);
        Snackbar.Add("Account created successfully!", Severity.Success);
        DialogInstance.Close();
        @* NavigationManager.NavigateTo("uri:/Accounts"); *@
        AccountService.GetAllAccountsAsync();
    }
   

private List<AccountType> acctype = new List<AccountType>();

protected override async Task OnInitializedAsync()
{
    try 
    {
        // Use the Async version of your service if available
        var types = await AccountTypeService.GetAllAccountTypes();
        if (types != null)
        {
            acctype = types;
            StateHasChanged();
            
        }
    }
    catch (Exception ex)
    {
        Snackbar.Add("Error loading account types", Severity.Error);
    }
}
}

