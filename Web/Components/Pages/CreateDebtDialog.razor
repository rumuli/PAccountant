@code {
    [CascadingParameter] 
     private IMudDialogInstance MudDialog { get; set; }

    private CreateDebtDTO Model { get; set; } = new();
    [Parameter] 
    public EventCallback OnDebtCreated { get; set; }
    
    private readonly DialogOptions _closeButton = new() { CloseButton = true };

    private bool ShowErrors { get; set; } = false;
    private List<DebtType> DebtTypes = new();
    

     private async Task OnValidSubmit()
    {
        try
        {
            await DebtService.CreateDebtAsync(Model);
            MudDialog.Close(DialogResult.Ok(true));

           }
           catch
           {

               ShowErrors = true;

           }
    }
    private void Cancel() => MudDialog.Cancel(); 
    


    protected override async Task OnInitializedAsync()
    {
        DebtTypes = await DebtTypeService.GetAllDebtTypesAsync();
        // Set default dates if necessary
        if (Model.DateIncurred == null) Model.DateIncurred = DateTime.Today;
    }



    private async Task GoToCreateDebtType()
    {
        var option = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<CreateDebtTypeDialog>("Create Debt Type", new DialogParameters {
            { "OnDebtTypeCreated", EventCallback.Factory.Create(this, async () => {
                DebtTypes = await DebtTypeService.GetAllDebtTypesAsync();
                StateHasChanged();
            })}
        }, option);
        await DialogService.ShowAsync<CreateDebtTypeDialog>("Create Debt Type", new DialogParameters {
            { "OnDebtTypeCreated", EventCallback.Factory.Create(this, async () => {
                DebtTypes = await DebtTypeService.GetAllDebtTypesAsync();
                StateHasChanged();
            })}
        }, option);
    }
}